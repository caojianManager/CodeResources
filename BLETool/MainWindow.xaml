<Window x:Class="BLETool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BLETool"
        mc:Ignorable="d"
        Title="Bluetooth LE 调试工具"
        Width="1500"
        Height="920"
        MinWidth="1280"
        MinHeight="760"
        Background="#D9E6F3"
        FontFamily="Microsoft YaHei UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.DataContext>
        <local:BleViewModel />
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#D9E6F3" />
        <SolidColorBrush x:Key="ChromeBrush" Color="#D3E2F2" />
        <SolidColorBrush x:Key="HeaderBrush" Color="#DCE9F7" />
        <SolidColorBrush x:Key="PanelBrush" Color="#F9FBFD" />
        <SolidColorBrush x:Key="BorderBrush" Color="#AFC3D8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0D72C6" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#075897" />
        <SolidColorBrush x:Key="TextBrush" Color="#1B1F23" />
        <SolidColorBrush x:Key="MutedBrush" Color="#637487" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#227A2E" />
        <SolidColorBrush x:Key="WarningBrush" Color="#B14A2A" />

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="HeaderBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource HeaderBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="ClassicButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#F6F9FC" />
            <Setter Property="BorderBrush" Value="#9EB7CF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E0ECF7" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ClassicButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2285D6" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0A5CA0" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="Button" BasedOn="{StaticResource ClassicButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Foreground" Value="#3D536B" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>

        <Style x:Key="ListHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="10,6" />
            <Setter Property="Foreground" Value="#31485F" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <Style x:Key="FieldValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="DeviceListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="ClassicDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#DDE7F1" />
            <Setter Property="VerticalGridLinesBrush" Value="#DDE7F1" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#CFE2F5" />
                        <Setter Property="Foreground" Value="#20384D" />
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0,0,1,0" />
                        <Setter Property="BorderBrush" Value="#E1EAF3" />
                        <Setter Property="Padding" Value="8,6" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WhenDeviceSelectedStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedDevice}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WhenNoDeviceStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedDevice}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WhenCharacteristicSelectedStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedCharacteristic}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WhenNoCharacteristicStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedCharacteristic}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WhenNotifyCharacteristicStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowNotifyMessages}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WhenWritableCharacteristicStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowWriteEditor}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WhenNotNotifyCharacteristicStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowNotifyMessages}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WhenReadCharacteristicStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowReadResult}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type local:BleGattServiceNode}" ItemsSource="{Binding Characteristics}">
            <StackPanel Margin="0,2">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                <TextBlock Margin="0,2,0,0"
                           Text="{Binding Uuid}"
                           FontSize="11"
                           Foreground="{StaticResource MutedBrush}"
                           FontFamily="Consolas" />
            </StackPanel>
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type local:BleGattCharacteristicNode}">
            <StackPanel Margin="0,4,0,2">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                <TextBlock Margin="0,2,0,0"
                           Text="{Binding Uuid}"
                           FontSize="11"
                           Foreground="{StaticResource MutedBrush}"
                           FontFamily="Consolas" />
                <TextBlock Margin="0,2,0,0"
                           Text="{Binding Properties}"
                           FontSize="11"
                           Foreground="{StaticResource AccentBrush}" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="3" Background="{StaticResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="28" />
            <RowDefinition Height="*" />
            <RowDefinition Height="22" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="580" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DockPanel Margin="8,2">
                <TextBlock Text="Bluetooth LE 调试工具"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="22,0,0,0">
                    <TextBlock Text="扫描(F)" Margin="0,0,18,0" VerticalAlignment="Center" Foreground="#334A62" />
                    <TextBlock Text="视图(V)" Margin="0,0,18,0" VerticalAlignment="Center" Foreground="#334A62" />
                    <TextBlock Text="设置(S)" Margin="0,0,18,0" VerticalAlignment="Center" Foreground="#334A62" />
                    <TextBlock Text="语言(L)" Margin="0,0,18,0" VerticalAlignment="Center" Foreground="#334A62" />
                    <TextBlock Text="帮助(H)" VerticalAlignment="Center" Foreground="#334A62" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="6" />
                <RowDefinition Height="280" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                        <RowDefinition Height="34" />
                        <RowDefinition Height="42" />
                        <RowDefinition Height="32" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
                        <DockPanel Margin="8,0">
                            <TextBlock Text="设备列表"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock DockPanel.Dock="Right"
                                       Text="×"
                                       FontSize="14"
                                       Foreground="#607386"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>

                    <DockPanel Grid.Row="1" Margin="8,0,8,0" LastChildFill="False">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Scanner" Command="{Binding ShowScannerCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsScannerMode}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Bonded" Command="{Binding ShowBondedCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBondedMode}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding DeviceCountText}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}" />
                    </DockPanel>

                    <Grid Grid.Row="2" Margin="8,6,8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="136" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="86" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="86" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,4"
                                 VerticalContentAlignment="Center"
                                 BorderBrush="#A7BED5"
                                 BorderThickness="1"
                                 Background="White" />

                        <ComboBox Grid.Column="2"
                                  VerticalContentAlignment="Center"
                                  BorderBrush="#A7BED5"
                                  BorderThickness="1"
                                  Background="White"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="显示所有设备" />
                            <ComboBoxItem Content="仅显示已配对" />
                        </ComboBox>

                        <Button Grid.Column="4" Content="开始扫描" Command="{Binding StartScanCommand}" Style="{StaticResource ClassicButtonStyle}" />
                        <Button Grid.Column="6" Content="停止扫描" Command="{Binding StopScanCommand}" Style="{StaticResource AccentButtonStyle}" />
                    </Grid>

                    <Grid Grid.Row="3" Background="#E6F0FA">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="230" />
                            <ColumnDefinition Width="85" />
                            <ColumnDefinition Width="125" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="设备" Style="{StaticResource ListHeaderTextStyle}" />
                        <TextBlock Grid.Column="1" Text="信号" Style="{StaticResource ListHeaderTextStyle}" />
                        <TextBlock Grid.Column="2" Text="地址" Style="{StaticResource ListHeaderTextStyle}" />
                        <TextBlock Grid.Column="3" Text="操作" Style="{StaticResource ListHeaderTextStyle}" />
                    </Grid>

                    <ListBox Grid.Row="4"
                             ItemsSource="{Binding DevicesView}"
                             SelectedItem="{Binding SelectedDevice}"
                             ItemContainerStyle="{StaticResource DeviceListBoxItemStyle}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="RowBorder"
                                        Background="Transparent"
                                        BorderBrush="#D8E3EE"
                                        BorderThickness="0,0,0,1"
                                        Padding="8,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="230" />
                                            <ColumnDefinition Width="85" />
                                            <ColumnDefinition Width="125" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Width="30" Height="30" Background="#1C94E8" CornerRadius="15" Margin="0,0,10,0">
                                                <TextBlock Text="BT"
                                                           Foreground="White"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource TextBrush}" />
                                                <TextBlock Margin="0,3,0,0"
                                                           Text="{Binding AdvertisementType}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource MutedBrush}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SignalText}"
                                                       Foreground="#334A62"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Margin="0,3,0,0"
                                                       Text="{Binding IsConnected, StringFormat=连接: {0}}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Address}"
                                                       Foreground="#334A62"
                                                       FontFamily="Consolas"
                                                       FontSize="12" />
                                            <TextBlock Margin="0,3,0,0"
                                                       Text="{Binding IsPaired, StringFormat=已配对: {0}}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="3"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                            <Button Content="连接"
                                                    Width="58"
                                                    Margin="0,0,6,0"
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    Command="{Binding DataContext.ConnectDeviceCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="配对"
                                                    Width="58"
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    Command="{Binding DataContext.PairDeviceCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                        <Setter TargetName="RowBorder" Property="Background" Value="#D8ECFF" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                        <Setter TargetName="RowBorder" Property="Background" Value="#EEF7FF" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="#C7D6E6" />

            <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                        <RowDefinition Height="92" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
                        <DockPanel Margin="8,0">
                            <TextBlock Text="广播数据"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding AdvertisementRows.Count, StringFormat=字段数: {0}}"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedBrush}" />
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="10,8,10,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="116" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="116" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ADV Address:" Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedDeviceAddress}" Style="{StaticResource FieldValueStyle}" FontFamily="Consolas" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="连接状态:" Style="{StaticResource FieldLabelStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding ConnectionStateText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource FieldValueStyle}">
                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Device Name:" Style="{StaticResource FieldLabelStyle}" Margin="0,8,0,2" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDeviceName}" Style="{StaticResource FieldValueStyle}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="广播类型:" Style="{StaticResource FieldLabelStyle}" Margin="0,8,0,2" />
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SelectedDeviceAdvertisementType}" Style="{StaticResource FieldValueStyle}" Margin="0,8,0,0" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="提示:" Style="{StaticResource FieldLabelStyle}" Margin="0,8,0,2" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                                   Text="选择左侧设备后，这里会展示对应广播字段和原始数据。"
                                   Style="{StaticResource FieldValueStyle}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource MutedBrush}" />
                    </Grid>

                    <DataGrid Grid.Row="2"
                              Margin="8,0,8,8"
                              ItemsSource="{Binding AdvertisementRows}"
                              Style="{StaticResource ClassicDataGridStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="70" />
                            <DataGridTextColumn Header="AD Type" Binding="{Binding AdType}" Width="220" />
                            <DataGridTextColumn Header="Data" Binding="{Binding Data}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#C7D6E6" />

        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="6" />
                <RowDefinition Height="190" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
                        <TextBlock Margin="8,0"
                                   Text="服务/特征调试"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center" />
                    </Border>

                    <Grid Grid.Row="1" Margin="8">
                        <Border Style="{StaticResource WhenNoDeviceStyle}" Background="White" BorderBrush="#D6E0EA" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="100" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#F1F5FA" BorderBrush="#D6E0EA" BorderThickness="0,0,0,1">
                                    <TextBlock Margin="18,0"
                                               Text="Bluetooth LE 调试工具"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextBrush}"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Row="1" Margin="18,24,18,18">
                                    <TextBlock Text="请在左侧设备列表中选择要调试的设备。"
                                               FontSize="14"
                                               Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="选中设备后可以查看广播信息、连接设备、浏览服务与特征，并进行读取、写入和通知调试。"
                                               FontSize="14"
                                               Foreground="{StaticResource TextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Style="{StaticResource WhenDeviceSelectedStyle}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#EEF4FA" BorderBrush="#D6E0EA" BorderThickness="1">
                                <Grid Margin="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedDeviceName}"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding SelectedDeviceAddress, StringFormat=MAC Address: {0}}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontFamily="Consolas" />
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Border Background="{StaticResource AccentBrush}" Padding="8,2" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding ConnectionStateText}" Foreground="White" FontWeight="SemiBold" />
                                            </Border>
                                            <Border Background="#D8E7F6" Padding="8,2" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding GattServices.Count, StringFormat=服务数: {0}}" Foreground="#21405C" />
                                            </Border>
                                            <Border Background="#D8E7F6" Padding="8,2">
                                                <TextBlock Text="{Binding AdvertisementRows.Count, StringFormat=广播字段: {0}}" Foreground="#21405C" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                        <Button Content="重新连接"
                                                Margin="0,0,8,0"
                                                Style="{StaticResource AccentButtonStyle}"
                                                Command="{Binding ReconnectCommand}" />
                                        <Button Content="断开"
                                                Margin="0,0,8,0"
                                                Style="{StaticResource ClassicButtonStyle}"
                                                Command="{Binding DisconnectCommand}" />
                                        <Button Content="刷新服务"
                                                Style="{StaticResource ClassicButtonStyle}"
                                                Command="{Binding RefreshServicesCommand}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="360" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="30" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
                                            <DockPanel Margin="8,0">
                                                <TextBlock Text="服务列表"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextBrush}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding ShowCharacteristics, StringFormat=特征展开: {0}}"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>
                                        </Border>
                                        <TreeView Grid.Row="1"
                                                  ItemsSource="{Binding GattServices}"
                                                  Padding="10"
                                                  Background="White"
                                                  BorderThickness="0"
                                                  SelectedItemChanged="GattTree_OnSelectedItemChanged" />
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                                    <Grid>
                                        <Border Style="{StaticResource WhenNoCharacteristicStyle}" Background="White">
                                            <StackPanel Margin="18,24">
                                                <TextBlock Text="请选择一个特征进行调试"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource TextBrush}" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Text="左侧服务树会列出当前设备的所有服务与特征。选中某个特征后，这里会显示 UUID、属性、通知数据，以及读取和写入操作。"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource MutedBrush}" />
                                            </StackPanel>
                                        </Border>

                                        <Grid Style="{StaticResource WhenCharacteristicSelectedStyle}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="82" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" Background="#EEF4FA" BorderBrush="#D6E0EA" BorderThickness="0,0,0,1">
                                                <Grid Margin="12,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="220" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding SelectedCharacteristicName}"
                                                                   FontSize="18"
                                                                   FontWeight="Bold"
                                                                   Foreground="{StaticResource TextBrush}" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding SelectedCharacteristicUuid, StringFormat=UUID: {0}}"
                                                                   FontFamily="Consolas"
                                                                   Foreground="{StaticResource MutedBrush}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding SelectedCharacteristicProperties, StringFormat=属性: {0}}"
                                                                   Foreground="#21405C" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding SelectedCharacteristicHandleText, StringFormat=Handle: {0}}"
                                                                   Foreground="#21405C" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Grid Grid.Row="1" Margin="12,12,12,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <DockPanel LastChildFill="False">
                                                    <TextBlock Text="特征数据"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource TextBrush}"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel DockPanel.Dock="Right"
                                                                Orientation="Horizontal"
                                                                Style="{StaticResource WhenNotifyCharacteristicStyle}">
                                                        <CheckBox Content="启用通知"
                                                                  VerticalAlignment="Center"
                                                                  IsChecked="{Binding NotifyEnabled}"
                                                                  IsEnabled="{Binding SelectedCharacteristicSupportsNotify}" />
                                                        <CheckBox Content="HEX 显示"
                                                                  Margin="14,0,0,0"
                                                                  VerticalAlignment="Center"
                                                                  IsChecked="{Binding ShowHex}" />
                                                    </StackPanel>
                                                </DockPanel>

                                                <StackPanel Grid.Row="1"
                                                            Margin="0,14,0,12"
                                                            Style="{StaticResource WhenNotifyCharacteristicStyle}">
                                                    <TextBlock Text="读取"
                                                               FontWeight="Bold"
                                                               FontSize="15"
                                                               Foreground="{StaticResource TextBrush}" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                        <TextBlock Text="接收："
                                                                   Style="{StaticResource FieldLabelStyle}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,4,0" />
                                                        <TextBlock Text="{Binding ReceivedBytesText}"
                                                                   Style="{StaticResource FieldValueStyle}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                        <TextBlock Text="实时速度："
                                                                   Style="{StaticResource FieldLabelStyle}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,4,0" />
                                                        <TextBlock Text="{Binding ReceiveSpeedText}"
                                                                   Style="{StaticResource FieldValueStyle}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </StackPanel>

                                                <Border Grid.Row="1"
                                                        Margin="0,14,0,12"
                                                        Background="#F5F9FC"
                                                        BorderBrush="#D9E4EF"
                                                        BorderThickness="1"
                                                        Padding="10,8"
                                                        Style="{StaticResource WhenReadCharacteristicStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="最近读取"
                                                                   Style="{StaticResource FieldLabelStyle}" />
                                                        <TextBlock Text="{Binding ReadValueText}"
                                                                   Margin="0,4,0,0"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   FontFamily="Consolas" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Grid Grid.Row="2" Margin="12,12,12,12">
                                                <Border Style="{StaticResource WhenNotifyCharacteristicStyle}"
                                                        BorderBrush="#BDD0E1"
                                                        BorderThickness="1"
                                                        Background="White">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Margin="10,8,10,0"
                                                                   Text="Notify 消息"
                                                                   FontWeight="Bold"
                                                                   FontSize="15"
                                                                   Foreground="{StaticResource TextBrush}" />
                                                        <ListBox Grid.Row="1"
                                                                 Margin="10,8,10,10"
                                                                 ItemsSource="{Binding NotificationMessages}"
                                                                 BorderBrush="#BDD0E1"
                                                                 BorderThickness="1"
                                                                 Background="White"
                                                                 FontFamily="Consolas"
                                                                 FontSize="12"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                                            <ListBox.ItemContainerStyle>
                                                                <Style TargetType="ListBoxItem">
                                                                    <Setter Property="Padding" Value="8,4" />
                                                                    <Setter Property="BorderBrush" Value="#EEF3F8" />
                                                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                                                </Style>
                                                            </ListBox.ItemContainerStyle>
                                                        </ListBox>
                                                    </Grid>
                                                </Border>

                                                <Border Style="{StaticResource WhenNotNotifyCharacteristicStyle}"
                                                        BorderBrush="#BDD0E1"
                                                        BorderThickness="1"
                                                        Background="#FBFDFF">
                                                    <StackPanel Margin="14,12">
                                                        <TextBlock Text="当前特征不显示 Notify 消息"
                                                                   FontWeight="Bold"
                                                                   FontSize="15"
                                                                   Foreground="{StaticResource TextBrush}" />
                                                        <TextBlock Margin="0,10,0,0"
                                                                   Text="如果该特征支持写入，可以在下方输入内容后点击“写入”发送数据。"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{StaticResource MutedBrush}" />
                                                        <TextBlock Margin="0,10,0,0"
                                                                   Text="若支持读取，上方会显示最近一次读取结果。"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{StaticResource MutedBrush}" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Grid Grid.Row="3" Margin="12,0,12,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Content="读取"
                                                        Style="{StaticResource ClassicButtonStyle}"
                                                        Command="{Binding ReadSelectedCommand}" />

                                                <Button Grid.Column="1"
                                                        Content="清空通知"
                                                        Margin="8,0,0,0"
                                                        Command="{Binding ClearNotificationsCommand}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShowNotifyMessages}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Grid Grid.Column="3"
                                                      Style="{StaticResource WhenWritableCharacteristicStyle}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding WriteData, UpdateSourceTrigger=PropertyChanged}"
                                                             Padding="8,4"
                                                             VerticalContentAlignment="Center"
                                                             BorderBrush="#A7BED5"
                                                             BorderThickness="1"
                                                             Background="White" />
                                                    <Button Grid.Column="2"
                                                            Content="写入"
                                                            Width="86"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Command="{Binding WriteCommand}" />
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#C7D6E6" />

            <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
                        <DockPanel Margin="8,0">
                            <TextBlock Text="日志窗口"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding Status}"
                                       Foreground="{StaticResource MutedBrush}"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Logs}"
                             Background="#FBFDFF"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="13"
                             Foreground="#0D5F27"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,3" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="BorderBrush" Value="#EDF2F7" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#0C6EBC" BorderBrush="#095892" BorderThickness="1,0,1,1">
            <DockPanel Margin="8,0">
                <TextBlock Text="{Binding Status}" Foreground="White" VerticalAlignment="Center" />
                <TextBlock Text=" | " Foreground="#CBE3F8" VerticalAlignment="Center" Margin="8,0" />
                <TextBlock Text="{Binding DeviceCountText}" Foreground="White" VerticalAlignment="Center" />
                <TextBlock DockPanel.Dock="Right" Text="蓝牙适配器版本: V5.4" Foreground="White" VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
