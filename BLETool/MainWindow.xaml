<Window x:Class="BLETool.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:BLETool" mc:Ignorable="d" Title="BLE Debug Tool" Width="1260" Height="820" MinWidth="1120" MinHeight="720" Background="#E5EEF7">
  <Window.DataContext><local:BleViewModel /></Window.DataContext>
  <Window.Resources>
    <SolidColorBrush x:Key="ChromeBrush" Color="#D4E2F1" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FAFCFE" />
    <SolidColorBrush x:Key="BorderBrush" Color="#A9BED3" />
    <SolidColorBrush x:Key="AccentBrush" Color="#0F77D7" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#085FAA" />
    <SolidColorBrush x:Key="GoodBrush" Color="#0A934A" />
    <SolidColorBrush x:Key="BadBrush" Color="#D93B3B" />
    <Style x:Key="PanelBorderStyle" TargetType="Border"><Setter Property="Background" Value="{StaticResource PanelBrush}" /><Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" /><Setter Property="BorderThickness" Value="1" /><Setter Property="CornerRadius" Value="3" /></Style>
    <Style x:Key="PrimaryButtonStyle" TargetType="Button"><Setter Property="Foreground" Value="White" /><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" /><Setter Property="BorderThickness" Value="1" /><Setter Property="Padding" Value="12,4" /><Setter Property="Cursor" Value="Hand" /><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3"><ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border></ControlTemplate></Setter.Value></Setter><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1A89EA" /></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45" /></Trigger></Style.Triggers></Style>
    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}"><Setter Property="Background" Value="#EDF4FB" /><Setter Property="Foreground" Value="#1C3953" /><Setter Property="BorderBrush" Value="#9BB5CD" /></Style>
    <Style x:Key="ModeButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}"><Setter Property="Background" Value="Transparent" /><Setter Property="BorderBrush" Value="Transparent" /><Setter Property="BorderThickness" Value="0,0,0,2" /><Setter Property="Padding" Value="12,6" /><Setter Property="Foreground" Value="#365470" /></Style>
    <Style x:Key="DeviceItemStyle" TargetType="ListBoxItem"><Setter Property="HorizontalContentAlignment" Value="Stretch" /><Setter Property="Padding" Value="0" /><Setter Property="Margin" Value="0,0,0,1" /><Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#D8ECFF" /></Trigger><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#EDF6FF" /></Trigger></Style.Triggers></Style>
    <HierarchicalDataTemplate DataType="{x:Type local:BleGattServiceNode}" ItemsSource="{Binding Characteristics}"><StackPanel Margin="0,2"><TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#1C2D3D" /><TextBlock Text="{Binding Uuid}" Foreground="#5E7388" FontSize="11" /></StackPanel></HierarchicalDataTemplate>
    <DataTemplate DataType="{x:Type local:BleGattCharacteristicNode}"><StackPanel Margin="0,4"><TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#1F3347" /><TextBlock Text="{Binding Uuid}" Foreground="#60788F" FontSize="11" /><TextBlock Text="{Binding Properties}" Foreground="#0F77D7" FontSize="11" /><TextBlock Text="{Binding Handle, StringFormat=Handle: {0}}" Foreground="#60788F" FontSize="11" /></StackPanel></DataTemplate>
  </Window.Resources>
  <Grid Margin="8">
    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="220" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
    <Grid.ColumnDefinitions><ColumnDefinition Width="440" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
    <Border Grid.Row="0" Grid.ColumnSpan="3" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,8"><DockPanel Background="{StaticResource ChromeBrush}" Margin="10,6"><TextBlock Text="BLE 调试工具 V1.2" FontWeight="Bold" Foreground="#1C2D3D" /><StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="20,0,0,0"><TextBlock Text="扫描(F)" Margin="0,0,18,0" Foreground="#243B52" /><TextBlock Text="视图(V)" Margin="0,0,18,0" Foreground="#243B52" /><TextBlock Text="设置(S)" Margin="0,0,18,0" Foreground="#243B52" /><TextBlock Text="Language(L)" Margin="0,0,18,0" Foreground="#243B52" /><TextBlock Text="帮助(H)" Foreground="#243B52" /></StackPanel></DockPanel></Border>
    <Grid Grid.Row="1" Grid.RowSpan="2" Grid.Column="0">
      <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="8" /><RowDefinition Height="220" /></Grid.RowDefinitions>
      <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
          <Border Grid.Row="0" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"><DockPanel Margin="10,6"><TextBlock Text="设备列表" FontWeight="Bold" Foreground="#1F3347" /><Button DockPanel.Dock="Right" Width="18" Height="18" Style="{StaticResource SecondaryButtonStyle}" Padding="0">×</Button></DockPanel></Border>
          <DockPanel Grid.Row="1" Margin="10,8,10,4"><StackPanel Orientation="Horizontal"><Button Content="Scanner" Command="{Binding ShowScannerCommand}"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource ModeButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding IsScannerMode}" Value="True"><Setter Property="Foreground" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /><Setter Property="FontWeight" Value="Bold" /></DataTrigger></Style.Triggers></Style></Button.Style></Button><Button Content="Bonded" Command="{Binding ShowBondedCommand}"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource ModeButtonStyle}"><Style.Triggers><DataTrigger Binding="{Binding IsBondedMode}" Value="True"><Setter Property="Foreground" Value="{StaticResource AccentBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /><Setter Property="FontWeight" Value="Bold" /></DataTrigger></Style.Triggers></Style></Button.Style></Button></StackPanel><TextBlock DockPanel.Dock="Right" Text="{Binding DeviceCountText}" Foreground="#5D748B" VerticalAlignment="Center" /></DockPanel>
          <Grid Grid.Row="2" Margin="10,0,10,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="8" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBox Grid.Column="0" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" Height="28" Padding="10,4" VerticalContentAlignment="Center" /><Button Grid.Column="2" Content="开始扫描" Command="{Binding StartScanCommand}" Style="{StaticResource SecondaryButtonStyle}" /><Button Grid.Column="4" Content="停止扫描" Command="{Binding StopScanCommand}" Style="{StaticResource PrimaryButtonStyle}" /></Grid>
          <Grid Grid.Row="3"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="10,0,10,0" Background="#E7F0F8"><Grid.ColumnDefinitions><ColumnDefinition Width="1.5*" /><ColumnDefinition Width="0.8*" /><ColumnDefinition Width="1*" /><ColumnDefinition Width="70" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="默认" Margin="10,7,0,7" FontWeight="SemiBold" Foreground="#35556F" /><TextBlock Grid.Column="1" Text="信号" Margin="10,7,0,7" FontWeight="SemiBold" Foreground="#35556F" /><TextBlock Grid.Column="2" Text="地址" Margin="10,7,0,7" FontWeight="SemiBold" Foreground="#35556F" /><TextBlock Grid.Column="3" Text="连接" HorizontalAlignment="Center" Margin="0,7,0,7" FontWeight="SemiBold" Foreground="#35556F" /><TextBlock Grid.Column="4" Text="配对" HorizontalAlignment="Center" Margin="0,7,0,7" FontWeight="SemiBold" Foreground="#35556F" /></Grid>
            <ListBox Grid.Row="1" ItemsSource="{Binding DevicesView}" SelectedItem="{Binding SelectedDevice}" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource DeviceItemStyle}">
              <ListBox.ItemTemplate><DataTemplate><Grid Margin="10,8"><Grid.ColumnDefinitions><ColumnDefinition Width="1.5*" /><ColumnDefinition Width="0.8*" /><ColumnDefinition Width="1*" /><ColumnDefinition Width="70" /><ColumnDefinition Width="70" /></Grid.ColumnDefinitions><StackPanel Grid.Column="0" Orientation="Horizontal"><Border Width="28" Height="28" CornerRadius="14" Background="#1593F0" Margin="0,0,10,0"><TextBlock Text="BT" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border><StackPanel><TextBlock Text="{Binding DisplayName}" FontWeight="Bold" Foreground="#17293B" /><TextBlock Text="{Binding Address}" Foreground="#6D8296" FontSize="11" /></StackPanel></StackPanel><StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="{Binding SignalText}" Foreground="#334C66" /><TextBlock Text="{Binding AdvertisementType}" Foreground="#7A8EA1" FontSize="11" /></StackPanel><StackPanel Grid.Column="2" VerticalAlignment="Center"><TextBlock Text="{Binding IsConnected, StringFormat=Connected: {0}}" Foreground="#334C66" /><TextBlock Text="{Binding IsPaired, StringFormat=Bonded: {0}}" Foreground="#7A8EA1" FontSize="11" /></StackPanel><Button Grid.Column="3" Content="连接" Margin="4,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding DataContext.ConnectDeviceCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" /><Button Grid.Column="4" Content="配对" Margin="4,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding DataContext.PairDeviceCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" /></Grid></DataTemplate></ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Grid>
      </Border>
      <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><Border Grid.Row="0" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"><DockPanel Margin="10,6"><TextBlock Text="广播数据" FontWeight="Bold" Foreground="#1F3347" /><TextBlock DockPanel.Dock="Right" Text="{Binding SelectedDevice.AdvertisementType, TargetNullValue=N/A}" Foreground="#567089" /></DockPanel></Border><DataGrid Grid.Row="1" Margin="8" ItemsSource="{Binding AdvertisementRows}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"><DataGrid.Columns><DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="70" /><DataGridTextColumn Header="AD Type" Binding="{Binding AdType}" Width="180" /><DataGridTextColumn Header="Data" Binding="{Binding Data}" Width="*" /></DataGrid.Columns></DataGrid></Grid></Border>
    </Grid>
    <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
      <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"><TextBlock Margin="10,6" Text="服务/特征调试" FontWeight="Bold" Foreground="#1F3347" /></Border>
        <Border Grid.Row="1" Background="#CFE3F7" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
          <Grid Margin="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <StackPanel>
              <Border Background="{StaticResource AccentBrush}" CornerRadius="3" Padding="10,4" HorizontalAlignment="Left"><TextBlock Text="{Binding SelectedDevice.DisplayName, TargetNullValue=No Device}" Foreground="White" FontWeight="Bold" /></Border>
              <StackPanel Orientation="Horizontal" Margin="0,12,0,2"><TextBlock Text="Device Name: " Foreground="#4A6278" /><TextBlock Text="{Binding SelectedDevice.DisplayName, TargetNullValue=--}" FontWeight="Bold" Foreground="#1A2E42" /></StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,2"><TextBlock Text="MAC Address: " Foreground="#4A6278" /><TextBlock Text="{Binding SelectedDevice.Address, TargetNullValue=--}" FontWeight="Bold" Foreground="#1A2E42" /></StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10"><TextBlock Text="Device Connected: " Foreground="#4A6278" /><TextBlock Text="{Binding ConnectionStateText}" FontWeight="Bold"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource BadBrush}" /><Style.Triggers><DataTrigger Binding="{Binding IsConnected}" Value="True"><Setter Property="Foreground" Value="{StaticResource GoodBrush}" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></StackPanel>
              <StackPanel Orientation="Horizontal"><CheckBox Content="Service" IsChecked="True" Margin="0,0,16,0" IsEnabled="False" /><CheckBox Content="Characteristics" IsChecked="{Binding ShowCharacteristics}" Margin="0,0,16,0" /><CheckBox Content="Only favourite" IsEnabled="False" /></StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top"><Button Content="重连" Margin="0,0,8,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ReconnectCommand}" /><Button Content="断开" Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DisconnectCommand}" /><Button Content="刷新服务" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefreshServicesCommand}" /></StackPanel>
          </Grid>
        </Border>
        <Grid Grid.Row="2" Margin="10"><Grid.ColumnDefinitions><ColumnDefinition Width="350" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
          <Border Grid.Column="0" BorderBrush="#C9D7E5" BorderThickness="1" Background="White"><TreeView ItemsSource="{Binding GattServices}" Padding="10" SelectedItemChanged="GattTree_OnSelectedItemChanged" /></Border>
          <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
            <Grid>
              <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
              <Border Grid.Row="0" Background="#CFE3F7" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"><StackPanel Margin="12,10"><TextBlock Text="{Binding SelectedCharacteristicName}" FontWeight="Bold" FontSize="16" Foreground="#1A2E42" /><TextBlock Margin="0,8,0,0" Text="{Binding SelectedCharacteristicUuid, StringFormat=UUID: {0}}" Foreground="#38526A" /><TextBlock Margin="0,6,0,0" Text="{Binding SelectedCharacteristicProperties, StringFormat=Properties: {0}}" Foreground="#38526A" /><TextBlock Margin="0,6,0,0" Text="{Binding SelectedCharacteristicHandleText, StringFormat=Handle: {0}}" Foreground="#38526A" /></StackPanel></Border>
              <Grid Grid.Row="1" Margin="12"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions><TextBlock Text="Notifications" FontWeight="Bold" FontSize="16" Foreground="#1A2E42" /><StackPanel Grid.Row="1" Margin="0,10,0,12"><CheckBox Content="Notify" IsChecked="{Binding NotifyEnabled}" IsEnabled="{Binding SelectedCharacteristic.SupportsNotify}" /><TextBlock Margin="0,14,0,4" Text="Read" FontWeight="Bold" Foreground="#1A2E42" /><StackPanel Orientation="Horizontal"><TextBlock Text="接收: " Foreground="#445F77" /><TextBlock Text="{Binding ReceivedBytesText}" Foreground="#1A2E42" /></StackPanel><StackPanel Orientation="Horizontal" Margin="0,4,0,0"><TextBlock Text="实时速度: " Foreground="#445F77" /><TextBlock Text="{Binding ReceiveSpeedText}" Foreground="#1A2E42" /><CheckBox Content="HEX 显示" Margin="18,0,0,0" IsChecked="{Binding ShowHex}" /></StackPanel></StackPanel><ListBox Grid.Row="2" ItemsSource="{Binding NotificationMessages}" BorderBrush="#BDD0E1" BorderThickness="1" Background="White" FontFamily="Consolas" FontSize="12" ScrollViewer.HorizontalScrollBarVisibility="Auto" /></Grid>
              <Grid Grid.Row="2" Margin="12"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><Button Grid.Column="0" Content="读取" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ReadSelectedCommand}" /><Button Grid.Column="1" Content="清空" Margin="8,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ClearNotificationsCommand}" /><TextBox Grid.Column="3" Margin="0,0,8,0" Height="28" VerticalContentAlignment="Center" Padding="8,4" Text="{Binding WriteData, UpdateSourceTrigger=PropertyChanged}" /><Button Grid.Column="4" Content="写入" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding WriteCommand}" /></Grid>
            </Grid>
          </Border>
        </Grid>
      </Grid>
    </Border>
    <Border Grid.Row="3" Grid.ColumnSpan="3" Style="{StaticResource PanelBorderStyle}" Margin="0,8,0,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="140" /></Grid.RowDefinitions><Border Grid.Row="0" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"><DockPanel Margin="10,6"><TextBlock Text="日志窗口" FontWeight="Bold" Foreground="#1F3347" /><TextBlock DockPanel.Dock="Right" Text="{Binding Status}" Foreground="#557087" /></DockPanel></Border><ListBox Grid.Row="1" ItemsSource="{Binding Logs}" Background="#FBFDFF" BorderThickness="0" FontFamily="Consolas" FontSize="13" Foreground="#0F6B32" ScrollViewer.HorizontalScrollBarVisibility="Auto"><ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="Padding" Value="10,2" /><Setter Property="BorderThickness" Value="0,0,0,1" /><Setter Property="BorderBrush" Value="#EDF2F7" /></Style></ListBox.ItemContainerStyle></ListBox></Grid></Border>
  </Grid>
</Window>
