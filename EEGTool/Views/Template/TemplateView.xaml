<UserControl x:Class="EEGTool.Views.Template.TemplateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:EEGTool.Views.Template"
             xmlns:vm="clr-namespace:EEGTool.ViewModels.Template"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">

    <UserControl.DataContext>
        <vm:TemplateViewModel/>
    </UserControl.DataContext>

    <Grid Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
        <Grid Background="Transparent" Cursor="">
            <Border>
                <Border.Background>
                    <LinearGradientBrush
                        StartPoint="1,0"
                        EndPoint="0,1">
                        <GradientStop
                            Color="#FFFFFF"
                            Offset="0" />
                        <GradientStop
                            Color="#D4EAFF"
                            Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <StackPanel HorizontalAlignment="Stretch"
                        VerticalAlignment="Top">
                <Grid Height="50">
                    <TextBlock Text="模板配置"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="16"
                               Foreground="#2f3542"
                               Margin="15,0,0,0"/>
                    <Grid HorizontalAlignment="Stretch"
                          VerticalAlignment="Bottom"
                          Height="0.50"
                          Background="LightGray"
                          Margin="5,0"></Grid>
                </Grid>
            </StackPanel>

            <Border CornerRadius="10"
                    BorderThickness="0.5"
                    BorderBrush="LightGray"
                    Background="White"
                    Margin="0,0,25,50"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24"
                                      ShadowDepth="3"
                                      Direction="270"
                                      Opacity="0.35"
                                      Color="#66000000"/>
                </Border.Effect>
                <Button Style="{StaticResource EffectActionButtonStyle}"
                        Width="135"
                        Height="35"
                        FontSize="14"
                        Content="新建模板"
                        Command="{Binding CreateTemplateCommand}" />
            </Border>

            <Grid Width="1"
                  Background="LightGray"
                  VerticalAlignment="Stretch"
                  HorizontalAlignment="Right"></Grid>
        </Grid>

        <Grid Grid.Column="1" Background="Transparent"></Grid>

        <Grid Grid.Column="0" Grid.ColumnSpan="2" Visibility="{Binding IsShowCreateTemplateWindow,Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="Black" Opacity="0.25"/>

            <Grid Width="500" Height="250">
                <Border BorderThickness="0.5" BorderBrush="LightGray" 
                        CornerRadius="8">
                    <Border.Background>
                        <LinearGradientBrush
                            StartPoint="1,0"
                            EndPoint="0,1">
                            <GradientStop
                                Color="#FFFFFF"
                                Offset="0" />
                            <GradientStop
                                Color="#D4EAFF"
                                Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="39"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <TextBlock Text="新建模板" 
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Grid HorizontalAlignment="Stretch"
                              VerticalAlignment="Bottom"
                              Height="1"
                              Background="LightGray"
                              Margin="15,0"></Grid>
                    </Grid>
                    
                    <Grid Grid.Row="1">
                        <Grid Width="300" Height="100"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="0,15,0,0"
                              Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1*"/>
                                <RowDefinition Height="2"/>
                                <RowDefinition Height="1*"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="模板名称:" 
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       FontSize="14"></TextBlock>

                            <Grid Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBox Height="30"
                                         Padding="8,4"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding TemplateName, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="BorderBrush" Value="#D9D9D9"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border x:Name="Bd"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="5"
                                                                SnapsToDevicePixels="True">
                                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsTemplateNameError, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                    <Setter Property="BorderBrush" Value="Red"/>
                                                    <Setter Property="BorderThickness" Value="1.5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <TextBlock Grid.Row="1"
                                           Margin="2,4,0,0"
                                           Foreground="Red"
                                           FontSize="12"
                                           Text="{Binding TemplateNameErrorMessage}"
                                           Visibility="{Binding IsTemplateNameError, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="采集时长:" 
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       FontSize="14"></TextBlock>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="2">

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Border CornerRadius="8"
                                    BorderThickness="0.5"
                                    BorderBrush="LightGray"
                                    Background="Transparent"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="24"
                                                      ShadowDepth="3"
                                                      Direction="270"
                                                      Opacity="0.35"
                                                      Color="#66000000"/>
                                </Border.Effect>
                                <Button Style="{StaticResource EffectActionButtonStyle}"
                                        Width="110"
                                        Height="30"
                                        FontSize="14"
                                        Content="确 认"
                                        Command="{Binding SureCreateTemplateCommand}" />
                            </Border>

                            <Border CornerRadius="8"
                                    BorderThickness="0.5"
                                    BorderBrush="LightGray"
                                    Background="Transparent"
                                    Margin="35,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="24"
                                                      ShadowDepth="3"
                                                      Direction="270"
                                                      Opacity="0.35"
                                                      Color="#66000000"/>
                                </Border.Effect>
                                <Button Style="{StaticResource EffectActionButtonStyle}"
                                        Width="110"
                                        Background="#861B2D"
                                        Foreground="White"
                                        Height="30"
                                        FontSize="14"
                                        Content="取 消"
                                        Command="{Binding CancelCreateCommand}" Cursor="Hand" />
                            </Border>
                        </StackPanel>
                        
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
