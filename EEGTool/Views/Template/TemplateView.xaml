<UserControl x:Class="EEGTool.Views.Template.TemplateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:EEGTool.Views.Template"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">
    <Grid Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
        <Grid Background="Transparent" Cursor="">
            <Border>
                <Border.Background>
                    <LinearGradientBrush
                        StartPoint="1,0"
                        EndPoint="0,1">
                        <GradientStop
                            Color="#FFFFFF"
                            Offset="0" />
                        <GradientStop
                            Color="#D4EAFF"
                            Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <StackPanel HorizontalAlignment="Stretch"
                        VerticalAlignment="Top">
                <Grid Height="50">
                    <TextBlock Text="模板配置"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="16"
                               Foreground="#2f3542"
                               Margin="15,0,0,0"/>
                    <Grid HorizontalAlignment="Stretch"
                          VerticalAlignment="Bottom"
                          Height="0.50"
                          Background="LightGray"
                          Margin="5,0"></Grid>
                </Grid>
            </StackPanel>

            <Border CornerRadius="10"
                    BorderThickness="0.5"
                    BorderBrush="LightGray"
                    Background="White"
                    Margin="0,0,25,50"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24"
                                      ShadowDepth="3"
                                      Direction="270"
                                      Opacity="0.35"
                                      Color="#66000000"/>
                </Border.Effect>
                <Button Style="{StaticResource EffectActionButtonStyle}"
                        Width="135"
                        Height="35"
                        FontSize="14"
                        Content="新建模板"
                        Command="{Binding CreateTemplateCommand}" />
            </Border>

            <Grid Width="1"
                  Background="LightGray"
                  VerticalAlignment="Stretch"
                  HorizontalAlignment="Right"></Grid>
        </Grid>

        <Grid Grid.Column="1" Background="Transparent"></Grid>

        <Grid Grid.Column="0" Grid.ColumnSpan="2">
            <Border Background="Black" Opacity="0.25"/>

            <Grid Width="500" Height="300">
                <Border BorderThickness="0.5" BorderBrush="LightGray" 
                        CornerRadius="8">
                    <Border.Background>
                        <LinearGradientBrush
                            StartPoint="1,0"
                            EndPoint="0,1">
                            <GradientStop
                                Color="#FFFFFF"
                                Offset="0" />
                            <GradientStop
                                Color="#D4EAFF"
                                Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <TextBlock Text="新建模板" 
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Grid HorizontalAlignment="Stretch"
                              VerticalAlignment="Bottom"
                              Height="1"
                              Background="LightGray"
                              Margin="15,0"></Grid>
                    </Grid>

                    <Grid Grid.Row="2">

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Border CornerRadius="8"
                                    BorderThickness="0.5"
                                    BorderBrush="LightGray"
                                    Background="White"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="24"
                                                      ShadowDepth="3"
                                                      Direction="270"
                                                      Opacity="0.35"
                                                      Color="#66000000"/>
                                </Border.Effect>
                                <Button Style="{StaticResource EffectActionButtonStyle}"
                                        Width="110"
                                        Height="30"
                                        FontSize="14"
                                        Content="确 认"
                                        Command="{Binding CreateTemplateCommand}" />
                            </Border>

                            <Border CornerRadius="8"
                                    BorderThickness="0.5"
                                    BorderBrush="LightGray"
                                    Background="Transparent"
                                    Margin="35,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="24"
                                                      ShadowDepth="3"
                                                      Direction="270"
                                                      Opacity="0.35"
                                                      Color="#66000000"/>
                                </Border.Effect>
                                <Button Style="{StaticResource EffectActionButtonStyle}"
                                        Width="110"
                                        Background="#861B2D"
                                        Foreground="White"
                                        Height="30"
                                        FontSize="14"
                                        Content="取 消"
                                        Command="{Binding CreateTemplateCommand}" />
                            </Border>
                        </StackPanel>
                        
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
