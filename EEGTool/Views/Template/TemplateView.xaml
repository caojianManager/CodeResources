<UserControl x:Class="EEGTool.Views.Template.TemplateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:br="clr-namespace:EEGTool.Views.Common"
             xmlns:local="clr-namespace:EEGTool.Views.Template"
             xmlns:hp="clr-namespace:FrameWork.Helper"
             xmlns:rs="clr-namespace:Resources"
             xmlns:numericUpDown="clr-namespace:FrameWork.UserControls.NumericUpDown"
             xmlns:vm="clr-namespace:EEGTool.ViewModels.Template"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">

    <UserControl.Resources>

        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="LightGray"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- 边框 -->
                            <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="17"/>

                            <!-- 显示选中项 -->
                            <ContentPresenter Margin="5,0,0,0"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Content="{TemplateBinding SelectionBoxItem}"/>

                            <ToggleButton x:Name="PART_DropDownToggle"
                                      Focusable="False"
                                      Cursor="Hand"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      BorderThickness="0"
                                      Background="Transparent">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0">
                                            <iconPacks:PackIconFontAwesome Kind="AngleDownSolid" 
                                                                    Margin="0,0,10,0"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center"
                                                                    Width="10" Height="5" 
                                                                    Foreground="#494D50"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Border" Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>


                            <!-- 下拉列表 -->
                            <Popup x:Name="PART_Popup"
                    VerticalOffset="10"
                    Placement="Bottom"
                    AllowsTransparency="True"
                    Focusable="False"
                    PopupAnimation="Slide"
                    IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="LightGray"
                        CornerRadius="0"
                        BorderThickness="1"
                        BorderBrush="LightGray"
                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>

                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EmptyListStyle" TargetType="ListBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Grid>
                            <!-- 数据项显示 -->
                            <ScrollViewer>
                                <ItemsPresenter />
                            </ScrollViewer>

                            <!-- 无数据占位 -->
                            <Grid x:Name="EmptyPlaceholder"
                                  Visibility="Collapsed"
                                  Background="Transparent">
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                    <iconPacks:PackIconTypicons Kind="ArrowBackOutline" Width="30" Height="30"
                                                                HorizontalAlignment="Center"
                                                                Foreground="Gray"
                                                                VerticalAlignment="Center"/>
                                    <TextBlock Text="添加电极和对应通道"
                                               Foreground="Gray"
                                               FontSize="12"
                                               Margin="0,10,0,0"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- 数据触发器 -->
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Items.Count, RelativeSource={RelativeSource Self}}" Value="0">
                                <Setter TargetName="EmptyPlaceholder" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ElectrodeScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Focusable="False"
                                                  IsTabStop="False"
                                                  Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb"
                                           MinHeight="32">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Width="6"
                                                        Margin="1,2"
                                                        Background="#C7D6E8"
                                                        CornerRadius="3"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#9DB9D8"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#7FA6CC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Focusable="False"
                                                  IsTabStop="False"
                                                  Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:TemplateViewModel/>
    </UserControl.DataContext>

    <Grid Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
        <Grid Background="Transparent" Cursor="">
            <Border>
                <Border.Background>
                    <LinearGradientBrush
                        StartPoint="1,0"
                        EndPoint="0,1">
                        <GradientStop
                            Color="#FFFFFF"
                            Offset="0" />
                        <GradientStop
                            Color="#D4EAFF"
                            Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <TextBlock Text="模板配置"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Top"
                       FontSize="16"
                       Foreground="Gray"
                       Margin="15,20,0,0"/>

            <Grid Height="1" HorizontalAlignment="Stretch"
                  VerticalAlignment="Top"
                  Margin="0,48,0,150"
                  Background="LightGray"/>
            <ListBox ItemsSource="{Binding Templates}" Margin="0,48,0,150"
                 SelectedItem="{Binding SelectedTemplate}"
                 BorderThickness="0"
                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Background="Transparent"
                 ScrollViewer.CanContentScroll="False"
                 VirtualizingStackPanel.IsVirtualizing="False"
                 SnapsToDevicePixels="True"
                 UseLayoutRounding="True"
                 Cursor=""
                  >
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="RootBorder"
                                            Margin="0"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="True">
                                        <!-- ContentPresenter 别忘了 ContentSource -->
                                        <ContentPresenter
                                        ContentSource="Content"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="75"
                              Margin="0"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">
                            <Grid Margin="0" Cursor="">
                                <Border BorderThickness="0,0,0,1"
                                        BorderBrush="LightGray"
                                        x:Name="STItemGrid" />

                                <iconPacks:PackIconGameIcons Kind="BrainTentacle"  Width="30" Height="30"
                                                             Margin="15,0,0,0"
                                                             HorizontalAlignment="Left"
                                                             VerticalAlignment="Center"
                                                             Foreground="#494D50"/>

                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Margin="65,0,0,0">
                                    <TextBlock Text="模板名称："   FontSize="14" Foreground="#494D50"/>
                                    <TextBlock      FontSize="14"
                                                    TextTrimming="CharacterEllipsis"
                                                    TextWrapping="NoWrap"
                                                    Foreground="#494D50"
                                                    Text="{Binding Name}" 
                                    />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Bottom"
                                            HorizontalAlignment="Right"
                                            Margin="65,20,10,5">
                                    <iconPacks:PackIconMaterial Kind="ClockTimeThreeOutline" 
                                                                Foreground="#494D50" 
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,10,0"
                                                                Width="12" Height="12"/>
                                    <TextBlock      FontSize="12"
                                                    Foreground="#494D50"
                                                    TextTrimming="CharacterEllipsis"
                                                    TextWrapping="NoWrap"
                                                    Text="{Binding FormattedTime}"/>

                                </StackPanel>

                            </Grid>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter TargetName="STItemGrid" Property="Background" >
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFE5A0" Offset="0"/>
                                            <GradientStop Color="#FFEEC1" Offset="0.5"/>
                                            <GradientStop Color="#FFDA7C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="False">
                                <Setter TargetName="STItemGrid" Property="Background" Value="Transparent"/>
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="False"/>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="STItemGrid" Property="Background" Value="LightGray"/>
                            </MultiDataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>


                </ListBox.ItemTemplate>
            </ListBox>

            <Border CornerRadius="10"
                    BorderThickness="0.5"
                    BorderBrush="LightGray"
                    Background="White"
                    Margin="0,0,25,50"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24"
                                      ShadowDepth="3"
                                      Direction="270"
                                      Opacity="0.35"
                                      Color="#66000000"/>
                </Border.Effect>
                <Button Style="{StaticResource EffectActionButtonStyle}"
                        Width="135"
                        Height="35"
                        FontSize="14"
                        Content="新建模板"
                        Command="{Binding CreateTemplateCommand}" />
            </Border>

            <Grid Width="1"
                  Background="LightGray"
                  VerticalAlignment="Stretch"
                  HorizontalAlignment="Right"></Grid>
        </Grid>

        <Grid Grid.Column="1" Background="WhiteSmoke">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>
            <Grid Width="500" Height="500">
                <br:BrainAreaView x:Name="TemplateBrainAreaView"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
            </Grid>

            <Grid Grid.Column="1">
                <Grid HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Margin="10,15,10,100">


                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,10,0,0">
                        <TextBlock Text="电极" FontSize="14" Foreground="Gray"/>
                        <TextBlock Text="通道" Margin="128,0,0,0" FontSize="14" Foreground="Gray"/>
                    </StackPanel>
                    <Grid Height="1" HorizontalAlignment="Stretch"
                          Background="LightGray"
                          VerticalAlignment="Top"
                          Margin="0,35,0,0"/>

                    <ListBox ItemsSource="{Binding Template.EleDirectory}" Margin="0,35,0,150"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Background="Transparent"
                             ScrollViewer.CanContentScroll="False"
                             VirtualizingStackPanel.IsVirtualizing="False"
                             SnapsToDevicePixels="True"
                             UseLayoutRounding="True"
                             Cursor="">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="RootBorder"
                                            Margin="0"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="True">
                                                <!-- ContentPresenter 别忘了 ContentSource -->
                                                <ContentPresenter
                                        ContentSource="Content"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="35"
                                      Margin="0"
                                      SnapsToDevicePixels="True"
                                      UseLayoutRounding="True">
                                    <Grid Margin="0" Cursor="">
                                        <Border BorderThickness="0,0,0,1"
                                        BorderBrush="LightGray"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="14" Foreground="Gray"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <iconPacks:PackIconUnicons Grid.Column="1" Kind="ArrowCircleRight" 
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="Gray"
                                                                       Width="20" Height="20"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Channel}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                   FontSize="14" Foreground="Gray"/>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
                

            </Grid>
        </Grid>


        <Grid Grid.Column="0" Grid.ColumnSpan="2" Visibility="{Binding IsShowCreateTemplateWindow,Converter={StaticResource BooleanToVisibilityConverter}}">
         

            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  Background="WhiteSmoke">
     

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    
                    <Grid Background="Transparent">
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush
                                    StartPoint="1,0"
                                    EndPoint="0,1">
                                    <GradientStop
                                        Color="#FFFFFF"
                                        Offset="0" />
                                    <GradientStop
                                        Color="#D4EAFF"
                                        Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Grid Height="35" 
                              Margin="0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Top">
                            <TextBlock Text="编辑模板" FontSize="14"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="10,0,0,2"
                                       Foreground="Gray"></TextBlock>
                            <Grid Background="LightGray" Height="1"
                                  Margin="10,0"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Bottom"/>
                        </Grid>

                        <StackPanel Margin="10,50,0,0"
                                    Orientation="Vertical">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">

                                <TextBlock Text="模板名称:" 
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       FontSize="14"></TextBlock>

                                <Grid VerticalAlignment="Center" Width="150"
                                      Margin="18,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBox Height="32"
                                         Padding="8,4"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding Template.Name, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="BorderBrush" Value="#D9D9D9"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <Border x:Name="Bd"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="5"
                                                                SnapsToDevicePixels="True">
                                                                <ScrollViewer x:Name="PART_ContentHost"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsTemplateNameError, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                        <Setter Property="BorderBrush" Value="Red"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <TextBlock Grid.Row="1"
                                           Margin="2,4,0,0"
                                           Foreground="Red"
                                           FontSize="12"
                                           Text="{Binding TemplateNameErrorMessage}"
                                           Visibility="{Binding IsTemplateNameError, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,15,0,0">
                                <TextBlock Text="采集时长:" 
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"
                                      FontSize="14"></TextBlock>

                                <Grid VerticalAlignment="Center" Width="150"
                                      Margin="18,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <numericUpDown:BZNumericUpDown Height="32"
                                                                    Width="150"
                                                                    IsDuration="True"
                                                                    DecimalPlaces="0"
                                                                    MinValue="0"
                                                                    MaxValue="359999"
                                                                    Step="60"
                                                                    Value="{Binding Template.Time, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <numericUpDown:BZNumericUpDown.Style>
                                            <Style TargetType="numericUpDown:BZNumericUpDown">
                                                <Setter Property="InputBorderBrush" Value="#D6D6D6"/>
                                                <Setter Property="InputBorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCollectionDurationError}" Value="True">
                                                        <Setter Property="InputBorderBrush" Value="Red"/>
                                                        <Setter Property="InputBorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </numericUpDown:BZNumericUpDown.Style>
                                    </numericUpDown:BZNumericUpDown>

                                    <TextBlock Grid.Row="1"
                                          Margin="2,4,0,0"
                                          Foreground="Red"
                                          VerticalAlignment="Center"
                                          FontSize="12"
                                          Text="{Binding CollectionDurationErrorMessage}"
                                          Visibility="{Binding IsCollectionDurationError, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <Grid Height="35" 
                              Margin="0,150,0,0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Top">
                            <TextBlock Text="电极配置" FontSize="14"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="10,0,0,2"
                                       Foreground="Gray"></TextBlock>
                            <Grid Background="LightGray" Height="1"
                                  Margin="10,0"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Bottom"/>
                        </Grid>

                        <ListBox
                                ItemsSource="{Binding Template.EleDirectory}"
                                SelectedValuePath="Channel"      
                                HorizontalAlignment="Stretch"
                                Margin="0,200,0,300"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                BorderThickness="0"
                                Background="Transparent"
                                Style="{StaticResource EmptyListStyle}">

                            <ListBox.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource ElectrodeScrollBarStyle}"/>
                            </ListBox.Resources>

                            <!-- 使用 WrapPanel 实现多列自动换行 -->
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Margin="0,0,0,0" IsItemsHost="True" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>

                            <!-- 每个 Item 的样式 -->
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="130" Height="45"
                                           Margin="10,0,0,10"
                                           Background="White"
                                           CornerRadius="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="BorderBrush" Value="LightGray"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsChannelConflict}" Value="True">
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                        <Setter Property="BorderBrush" Value="Red"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>

                                            <ComboBox Width="101" Height="34"
                                                       FontSize="14"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       Margin="5,0,0,0"
                                                       ItemsSource="{Binding DataContext.ComboxItems, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       SelectedItem="{Binding Channel, Mode=TwoWay}"
                                                       Style="{StaticResource ModernComboBoxStyle}" Cursor=""/>
                                            <Grid Width="34" Height="34"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Margin="5,0,0,0">
                                                <Border CornerRadius="17">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#BADEFF" Offset="0"/>
                                                            <GradientStop Color="#A2D2FF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Text="{Binding Name}"/>
                                            </Grid>
                                            <Button HorizontalAlignment="Right"
                                 Margin="0,5,5,0"
                                 VerticalAlignment="Top"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 hp:ButtonHelper.CornerRadius="0,10,0,0"
                                 Width="10" Height="10" Cursor="Hand"
                                 CommandParameter="{Binding}"
                                 Command="{Binding DataContext.DeleteElectrodeCommand,RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                <iconPacks:PackIconMaterial Kind="WindowClose" 
                                                         Width="9" Height="9" 
                                                         Foreground="#494D50"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                            <!-- 去掉系统选中样式，但保留内容 -->
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="OverridesDefaultStyle" Value="True"/>

                                    <!-- ✳️ 必须手动加上 Template，告诉它怎么显示内容 -->
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <!-- 用 ContentPresenter 显示绑定内容 -->
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>

                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <TextBlock Margin="12,0,0,100"
                                   Foreground="Red"
                                   FontSize="12"
                                   Text="{Binding ElectrodeErrorMessage}"
                                   Visibility="{Binding IsElectrodeError, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Bottom"/>

                        <Grid HorizontalAlignment="Stretch"
                              VerticalAlignment="Bottom"
                              Height="100">

                            <StackPanel Orientation="Horizontal"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                <Border CornerRadius="8"
                                          BorderThickness="0.5"
                                          BorderBrush="LightGray"
                                          Background="Transparent"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24"
                                        ShadowDepth="3"
                                        Direction="270"
                                        Opacity="0.35"
                                        Color="#66000000"/>
                                    </Border.Effect>
                                    <Button Style="{StaticResource EffectActionButtonStyle}"
                                              Width="110"
                                              Height="35"
                                              FontSize="16"
                                              Content="保 存"
                                              Command="{Binding SureCreateTemplateCommand}" />
                                </Border>

                                <Border CornerRadius="8"
                                      BorderThickness="0.5"
                                      BorderBrush="LightGray"
                                      Background="Transparent"
                                      Margin="35,0,0,0"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" Cursor="">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24"
                                        ShadowDepth="3"
                                        Direction="270"
                                        Opacity="0.35"
                                        Color="#66000000"/>
                                    </Border.Effect>
                                    <Button Style="{StaticResource EffectActionButtonStyle}"
                                              Width="110"
                                              Background="#861B2D"
                                              Foreground="White"
                                              Height="35"
                                              FontSize="16"
                                              Content="取 消"
                                              Command="{Binding CancelCreateCommand}" Cursor="Hand" />
                                </Border>
                            </StackPanel>

                        </Grid>

                        <Grid Background="LightGray" Width="0.5" 
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Right"/>
                    </Grid>

                    <Grid Grid.Column="1" Background="White">
                        <Grid Width="500" Height="500">
                            <br:BrainAreaView x:Name="BrainAreaView"
                                              IsReadOnly="False"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Grid>

             

              
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
