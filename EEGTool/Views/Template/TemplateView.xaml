<UserControl x:Class="EEGTool.Views.Template.TemplateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:EEGTool.Views.Template"
             xmlns:vm="clr-namespace:EEGTool.ViewModels.Template"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">

    <UserControl.DataContext>
        <vm:TemplateViewModel/>
    </UserControl.DataContext>

    <Grid Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
        <Grid Background="Transparent" Cursor="">
            <Border>
                <Border.Background>
                    <LinearGradientBrush
                        StartPoint="1,0"
                        EndPoint="0,1">
                        <GradientStop
                            Color="#FFFFFF"
                            Offset="0" />
                        <GradientStop
                            Color="#D4EAFF"
                            Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <StackPanel HorizontalAlignment="Stretch"
                        VerticalAlignment="Top">
                <Grid Height="50">
                    <TextBlock Text="模板配置"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="16"
                               Foreground="#2f3542"
                               Margin="15,0,0,0"/>
                    <Grid HorizontalAlignment="Stretch"
                          VerticalAlignment="Bottom"
                          Height="0.50"
                          Background="LightGray"
                          Margin="5,0"></Grid>
                </Grid>
            </StackPanel>

            <Border CornerRadius="10"
                    BorderThickness="0.5"
                    BorderBrush="LightGray"
                    Background="White"
                    Margin="0,0,25,50"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24"
                                      ShadowDepth="3"
                                      Direction="270"
                                      Opacity="0.35"
                                      Color="#66000000"/>
                </Border.Effect>
                <Button Style="{StaticResource EffectActionButtonStyle}"
                        Width="135"
                        Height="35"
                        FontSize="14"
                        Content="新建模板"
                        Command="{Binding CreateTemplateCommand}" />
            </Border>

            <Grid Width="1"
                  Background="LightGray"
                  VerticalAlignment="Stretch"
                  HorizontalAlignment="Right"></Grid>
        </Grid>

        <Grid Grid.Column="1" Background="Transparent"></Grid>

        <Grid Grid.Column="0" Grid.ColumnSpan="2" Visibility="{Binding IsShowCreateTemplateWindow,Converter={StaticResource BooleanToVisibilityConverter}}">
         

            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  Background="WhiteSmoke">
     

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    
                    <Grid Background="Transparent">

                        <Grid Height="35" 
                              Margin="0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Top">
                            <TextBlock Text="编辑模板" FontSize="14"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="10,0,0,2"
                                       Foreground="Gray"></TextBlock>
                            <Grid Background="LightGray" Height="1"
                                  Margin="10,0"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Bottom"/>
                        </Grid>

                        <StackPanel Margin="10,50,0,0"
                                    Orientation="Vertical">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">

                                <TextBlock Text="模板名称:" 
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       FontSize="14"></TextBlock>

                                <Grid VerticalAlignment="Center" Width="200"
                                      Margin="18,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBox Height="30"
                                         Padding="8,4"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding TemplateName, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="BorderBrush" Value="#D9D9D9"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <Border x:Name="Bd"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="5"
                                                                SnapsToDevicePixels="True">
                                                                <ScrollViewer x:Name="PART_ContentHost"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsTemplateNameError, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                        <Setter Property="BorderBrush" Value="Red"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <TextBlock Grid.Row="1"
                                           Margin="2,4,0,0"
                                           Foreground="Red"
                                           FontSize="12"
                                           Text="{Binding TemplateNameErrorMessage}"
                                           Visibility="{Binding IsTemplateNameError, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,15,0,0">
                                <TextBlock Text="采集时长:" 
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"
                                      FontSize="14"></TextBlock>

                                <Grid VerticalAlignment="Center" Width="200"
                                      Margin="16,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                        Height="30"
                                        Padding="8,4"
                                        VerticalContentAlignment="Center"
                                        Text="{Binding CollectionDuration, UpdateSourceTrigger=PropertyChanged}"
                                        InputMethod.IsInputMethodEnabled="False"
                                        PreviewTextInput="DurationTextBox_PreviewTextInput"
                                        DataObject.Pasting="DurationTextBox_OnPasting"
                                        TextChanged="DurationTextBox_TextChanged">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="BorderBrush" Value="#D9D9D9"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <Border x:Name="Bd"
                                                               Background="{TemplateBinding Background}"
                                                               BorderBrush="{TemplateBinding BorderBrush}"
                                                               BorderThickness="{TemplateBinding BorderThickness}"
                                                               CornerRadius="5"
                                                               SnapsToDevicePixels="True">
                                                                <ScrollViewer x:Name="PART_ContentHost"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsCollectionDurationError, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                        <Setter Property="BorderBrush" Value="Red"/>
                                                        <Setter Property="BorderThickness" Value="1.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <TextBlock Grid.Column="1"
                                          Margin="6,0,0,0"
                                          VerticalAlignment="Center"
                                          FontSize="14"
                                          Text="秒"/>

                                    <TextBlock Grid.Row="1"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          Margin="2,4,0,0"
                                          Foreground="Red"
                                          VerticalAlignment="Center"
                                          FontSize="12"
                                          Text="{Binding CollectionDurationErrorMessage}"
                                          Visibility="{Binding IsCollectionDurationError, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <Grid HorizontalAlignment="Stretch"
                              VerticalAlignment="Bottom"
                              Height="100">

                            <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                                <Border CornerRadius="8"
                      BorderThickness="0.5"
                      BorderBrush="LightGray"
                      Background="Transparent"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24"
                                        ShadowDepth="3"
                                        Direction="270"
                                        Opacity="0.35"
                                        Color="#66000000"/>
                                    </Border.Effect>
                                    <Button Style="{StaticResource EffectActionButtonStyle}"
                          Width="110"
                          Height="30"
                          FontSize="14"
                          Content="保 存"
                          Command="{Binding SureCreateTemplateCommand}" />
                                </Border>

                                <Border CornerRadius="8"
                      BorderThickness="0.5"
                      BorderBrush="LightGray"
                      Background="Transparent"
                      Margin="35,0,0,0"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="24"
                                        ShadowDepth="3"
                                        Direction="270"
                                        Opacity="0.35"
                                        Color="#66000000"/>
                                    </Border.Effect>
                                    <Button Style="{StaticResource EffectActionButtonStyle}"
                          Width="110"
                          Background="#861B2D"
                          Foreground="White"
                          Height="30"
                          FontSize="14"
                          Content="取 消"
                          Command="{Binding CancelCreateCommand}" Cursor="Hand" />
                                </Border>
                            </StackPanel>

                        </Grid>
                    </Grid>

                    <Grid Grid.Column="1" Background="White">

                    </Grid>

             

              
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
