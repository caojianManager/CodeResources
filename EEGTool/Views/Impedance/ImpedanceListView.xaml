<UserControl x:Class="EEGTool.Views.Impedance.ImpedanceListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:nu="clr-namespace:FrameWork.UserControls.NumericUpDown"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:EEGTool.Views.Impedance"
             xmlns:vm="clr-namespace:EEGTool.ViewModels.Impedance"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">
    <UserControl.DataContext>
        <vm:ImpedanceListViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="WhiteSmoke" Grid.ColumnSpan="2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <StackPanel
                Orientation="Horizontal"
                Margin="0,0,15,0"
                Width="180"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">
                    <TextBlock
                    FontSize="14"
                    Margin="0,0,15,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Text="良好阈值"
                    Foreground="DarkOrange"/>
                    <nu:BZNumericUpDown
                    Width="100"
                    Height="30"
                    MaxValue="600"
                    MinValue="1"
                    IsDecimal="False"
                    Value="{Binding ThresholdGoodKohm}"
                    Step="1" />
                </StackPanel>
                <StackPanel
                Orientation="Horizontal"
                Margin="0,0,15,0"
                Width="180"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">
                    <TextBlock
                    FontSize="14"
                    Margin="0,0,15,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Text="警告阈值"
                    Foreground="Red"/>
                    <nu:BZNumericUpDown
                    Width="100"
                    Height="30"
                    MaxValue="600"
                    MinValue="1"
                    IsDecimal="False"
                    Value="{Binding ThresholdWarnKohm}"
                    Step="1" />
                </StackPanel>
                <TextBlock Text="{Binding SampleInfo}"
                           FontSize="13"
                           Margin="0,0,15,0"
                           Foreground="Gray"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Grid Height="1"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Bottom"
                  Background="LightGray"></Grid>
        </Grid>

        <Grid Grid.Row="1" Grid.ColumnSpan="2" Background="White">
            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                   Width="500"> 
                    <Border BorderThickness="0.5" BorderBrush="LightGray" Margin="-50" CornerRadius="5">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18"
                                              ShadowDepth="2"
                                              Direction="270"
                                              Opacity="0.25"
                                              Color="#000000"/>
                        </Border.Effect>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                             VerticalAlignment="Top"
                             Margin="0,10,0,0">
                    <TextBlock Text="电极/通道" FontSize="16" Foreground="Gray"/>
                    <TextBlock Text="阻抗值" Margin="260,0,0,0" FontSize="16" Foreground="Gray"/>
                </StackPanel>
                <Grid Height="1" HorizontalAlignment="Stretch"
                       Background="LightGray"
                       VerticalAlignment="Top"
                       Margin="0,35,0,0"/>

                <ListBox ItemsSource="{Binding Items}" Margin="0,35,0,10"
                          BorderThickness="0"
                          ScrollViewer.VerticalScrollBarVisibility="Hidden"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Background="Transparent"
                          ScrollViewer.CanContentScroll="False"
                          VirtualizingStackPanel.IsVirtualizing="False"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True"
                          Cursor="">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="RootBorder"
                                         Margin="0"
                                         Background="{TemplateBinding Background}"
                                         BorderBrush="{TemplateBinding BorderBrush}"
                                         BorderThickness="{TemplateBinding BorderThickness}"
                                         Padding="{TemplateBinding Padding}"
                                         SnapsToDevicePixels="True">
                                            <!-- ContentPresenter 别忘了 ContentSource -->
                                            <ContentPresenter
                                     ContentSource="Content"
                                     HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                     VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="35"
                                   Margin="0"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True">
                                <Grid Margin="0" Cursor="">
                                    <Border BorderThickness="0,0,0,1"
                                     BorderBrush="LightGray"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding NameAndChannel}" 
                                                    FontSize="14" Foreground="Gray"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Margin="25,0,0,0"/>

                                        <iconPacks:PackIconUnicons Grid.Column="1" Kind="ArrowCircleRight" 
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="Gray"
                                                                    Width="20" Height="20"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ImpedanceValue}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                FontSize="14" Foreground="{Binding ImpedanceBrush}"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
