<UserControl x:Class="EEGTool.Views.Impedance.ImpedanceFFTView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EEGTool.Views.Impedance"
             xmlns:vm="clr-namespace:EEGTool.ViewModels.Impedance"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.DataContext>
        <vm:ImpedanceFFTViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="OtherBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- 边框 -->
                            <Border x:Name="Border"
                               Background="{TemplateBinding Background}"
                               BorderBrush="{TemplateBinding BorderBrush}"
                               BorderThickness="1"
                               CornerRadius="5"/>

                            <!-- 显示选中项 -->
                            <ContentPresenter 
                                           Margin="-5,0,0,0"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Content="{TemplateBinding SelectionBoxItem}"
                                           ContentTemplate="{TemplateBinding ItemTemplate}"/>


                            <ToggleButton x:Name="PART_DropDownToggle"
                                         Focusable="False"
                                         Cursor="Hand"
                                         IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center"
                                         Width="{TemplateBinding Width}"
                                         Height="{TemplateBinding Height}"
                                         BorderThickness="0"
                                         Background="Transparent">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border"
                                               Background="Transparent"
                                               BorderBrush="Transparent"
                                               BorderThickness="0">
                                            <Path Data="M 0 0 L 8 8 L 16 0 Z"
                                                 Fill="Black"
                                                 Width="10"
                                                 Height="6"
                                                 Margin="0,0,10,0"
                                                 Stretch="Uniform"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Border" Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>


                            <!-- 下拉列表 -->
                            <Popup x:Name="PART_Popup"
                                   VerticalOffset="5"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="LightGray"
                                       CornerRadius="0"
                                       BorderThickness="1"
                                       BorderBrush="LightGray"
                                       MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>

                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border BorderThickness="0.5" BorderBrush="LightGray"/>
        <Grid Background="#111820" Margin="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Background="#18232D">

                <StackPanel Orientation="Horizontal" 
                     HorizontalAlignment="Right"
                     Margin="0,12,34,0"
                     VerticalAlignment="Top">
                    <StackPanel>
                        <ComboBox Width="100" Height="30"
                           HorizontalAlignment="Left"
                           FontSize="12"
                           VerticalAlignment="Top"
                           ItemsSource="{Binding MaxWindowHz}"
                           SelectedItem="{Binding SelectedMaxWindowHz}"
                           Style="{StaticResource OtherBoxStyle}">
                        </ComboBox>
                        <TextBlock FontSize="12"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Text="窗口最大频率Hz"/>
                    </StackPanel>

                    <StackPanel Margin="24,0,0,0">
                        <ComboBox Width="100" Height="30"
                           HorizontalAlignment="Left"
                           FontSize="12"
                           VerticalAlignment="Top"
                           ItemsSource="{Binding MaxWindowUv}"
                           SelectedItem="{Binding SelectedMaxWindowUv}"
                           Style="{StaticResource OtherBoxStyle}">
                        </ComboBox>
                        <TextBlock FontSize="12"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Text="窗口最大电压μV"/>
                    </StackPanel>

                    <StackPanel Margin="24,0,0,0">
                        <ComboBox Width="100" Height="30"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           FontSize="12"
                           ItemsSource="{Binding YAxesType}"
                           SelectedItem="{Binding SelectedYAxesType}"
                           Style="{StaticResource OtherBoxStyle}">
                        </ComboBox>
                        <TextBlock FontSize="12"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Text="Log/Lin"/>
                    </StackPanel>

                    <StackPanel Margin="10,0,0,0">
                        <ComboBox Width="100" Height="30"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           FontSize="12"
                           ItemsSource="{Binding SmoothingFactor}"
                           SelectedItem="{Binding SelectedSmoothingFactor}"
                           Style="{StaticResource OtherBoxStyle}">
                        </ComboBox>
                        <TextBlock FontSize="12"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Text="平滑系数"/>
                    </StackPanel>

                </StackPanel>
            </Grid>
            <Grid Grid.Row="1">
                <ContentControl  
             Margin="12,0,12,12"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Content="{Binding FftPlot, Mode=OneTime}" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
