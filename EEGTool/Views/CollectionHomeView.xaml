<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:rs="clr-namespace:Resources"
                    xmlns:vm="clr-namespace:EEGTool.ViewModels">
    <DataTemplate DataType="{x:Type vm:CollectionHomeViewModel}">
        <Grid HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Image Source="{x:Static rs:ResourcesImagePath.SYSTEM_BG}"  Stretch="UniformToFill"/>
        </Grid>
    </DataTemplate>
</ResourceDictionary>