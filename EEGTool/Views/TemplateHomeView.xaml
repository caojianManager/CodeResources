<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:vm="clr-namespace:EEGTool.ViewModels"
                    xmlns:tpv="clr-namespace:EEGTool.Views.Template"
                    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataTemplate DataType="{x:Type vm:TemplateHomeViewModel}">


        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="39"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <Grid Background="White">
                <Border>

                    <Border.Background>
                        <LinearGradientBrush
                            StartPoint="1,0"
                            EndPoint="0,1">
                            <GradientStop
                                Color="#FFFFFF"
                                Offset="0" />
                            <GradientStop
                                Color="#D4EAFF"
                                Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom">

                    <Button Style="{StaticResource HomeIconButtonStyle}"
                            Margin="8,0,0,3"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Command="{Binding BackHomeCommand}"
                            ToolTip="返回首页">
                        <iconPacks:PackIconGameIcons Kind="Brain"
                                                     Width="20"
                                                     Height="20"
                                                     Foreground="#4D4D4D" />
                    </Button>
                    </StackPanel>
                </Grid>
            <tpv:TemplateView Grid.Row="1"/>
            </Grid>
    </DataTemplate>
</ResourceDictionary>