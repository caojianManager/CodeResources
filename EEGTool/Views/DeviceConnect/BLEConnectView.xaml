<UserControl x:Class="EEGTool.Views.DeviceConnect.BLEConnectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EEGTool.Views.DeviceConnect"
             xmlns:vm="clr-namespace:EEGTool.ViewModels.DeviceConnect"
             xmlns:hp="clr-namespace:FrameWork.Helper"
             xmlns:rs="clr-namespace:Resources"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">

    <UserControl.DataContext>
        <vm:DeviceConnectViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid Width="390" Height="600">

            <Border CornerRadius="10">
                <Border.Background>
                    <LinearGradientBrush
                  StartPoint="1,0"
                  EndPoint="0,1">
                        <GradientStop
                      Color="#FFFFFF"
                      Offset="0" />
                        <GradientStop
                      Color="#D4EAFF"
                      Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>


                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                ShadowDepth="2"
                                Direction="270"
                                Opacity="0.25"
                                Color="#000000"/>
                </Border.Effect>
            </Border>


            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="39"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>

                    <TextBlock Text="蓝牙连接" 
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
                    <Grid Background="LightGray" Height="0.5"
                    HorizontalAlignment="Stretch"
                    Margin="15,0"
                    VerticalAlignment="Bottom"></Grid>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
