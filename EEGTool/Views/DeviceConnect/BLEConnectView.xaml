<UserControl x:Class="EEGTool.Views.DeviceConnect.BLEConnectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EEGTool.Views.DeviceConnect"
             xmlns:vm="clr-namespace:EEGTool.ViewModels.DeviceConnect"
             xmlns:hp="clr-namespace:FrameWork.Helper"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:rs="clr-namespace:Resources"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">

    <UserControl.DataContext>
        <vm:DeviceConnectViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <SolidColorBrush x:Key="MutedBrush" Color="#637487" />
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style x:Key="ConnectActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0071BC" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#0071BC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.90" ScaleY="0.90" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>


    <Grid>
        <Grid Width="390" Height="600">

            <Border CornerRadius="10">
                <Border.Background>
                    <LinearGradientBrush
                  StartPoint="1,0"
                  EndPoint="0,1">
                        <GradientStop
                      Color="#FFFFFF"
                      Offset="0" />
                        <GradientStop
                      Color="#D4EAFF"
                      Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>


                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                ShadowDepth="2"
                                Direction="270"
                                Opacity="0.25"
                                Color="#000000"/>
                </Border.Effect>
            </Border>


            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="39"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="100"/>
            
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>

                    <TextBlock Text="蓝牙连接" 
                         HorizontalAlignment="Center"
                         FontSize="14"
                         VerticalAlignment="Center"/>
                    <Grid Background="LightGray" Height="0.5"
                    HorizontalAlignment="Stretch"
                    Margin="15,0"
                    VerticalAlignment="Bottom"></Grid>
                </Grid>
                <Grid Grid.Row="2" HorizontalAlignment="Stretch"
                      Margin="15,0">
                    <Border Background="Transparent" BorderThickness="0.5"
                            BorderBrush="LightGray"
                            CornerRadius="5"></Border>

                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="ADV Address:" 
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelStyle}"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="连接状态:" 
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelStyle}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="设备名称:" 
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelStyle}"/>

                        <TextBlock Grid.Row="1" Grid.Column="2" Text="广播类型:" 
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelStyle}"/>

                        <TextBlock Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="4"
                                   Text="提示：此处显示当前连接设备信息，连接成功后去完成采集配置."
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelStyle}"></TextBlock>
                    </Grid>
                </Grid>

                <ListBox Grid.Row="3"
                          ItemsSource="{Binding BtDevices}"
                          Margin="15,25,15,80"
                          BorderThickness="0"
                          ScrollViewer.VerticalScrollBarVisibility="Hidden"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Background="Transparent"
                          ScrollViewer.CanContentScroll="False"
                          VirtualizingStackPanel.IsVirtualizing="False"
                          SelectedItem="{Binding SelectedBtDevice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="Transparent" BorderThickness="0">
                                            <ContentPresenter
                                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="50" Margin="3,2,3,3">
                                <Border x:Name="ItemBackground"
                                        CornerRadius="5"
                                        Background="White"
                                        BorderThickness="0.5"
                                        BorderBrush="LightGray">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10"
                                                          ShadowDepth="1"
                                                          Direction="270"
                                                          Opacity="0.1"
                                                          Color="#66000000"/>
                                    </Border.Effect>

                                    <Grid>
                                        <Border Width="35" Height="35" 
                                                HorizontalAlignment="Left"
                                                Margin="15,0,0,0"
                                                VerticalAlignment="Center"
                                                BorderThickness="1"
                                                CornerRadius="17.5"
                                                BorderBrush="LightGray">
                                            <Border.Background>
                                                <LinearGradientBrush
                                                    StartPoint="1,0"
                                                    EndPoint="0,1">
                                                    <GradientStop
                                                        Color="#FFFFFF"
                                                        Offset="0" />
                                                    <GradientStop
                                                        Color="#D4EAFF"
                                                        Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <iconPacks:PackIconForkAwesome Kind="Bluetooth" 
                                                                           Foreground="Gray"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Orientation="Vertical" Margin="60,0,120,0"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="14" Foreground="Black"/>
                                            <TextBlock Text="{Binding Address}" FontSize="10" Foreground="Gray"></TextBlock>
                                        </StackPanel>

                                        <Grid Width="80" Height="25"
                                              Margin="0,0,15,0"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center">
                                            <Button VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    Width="80" Height="25"
                                                    Style="{StaticResource ConnectActionButtonStyle}"
                                                    Padding="0"
                                                    Content="连  接"
                                                    BorderThickness="0"
                                                    Background="#0071BC"
                                                    Foreground="White"/>
                                        </Grid>
                                       
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>


                </ListBox>

                <Grid Grid.Row="3" ClipToBounds="False">
                    <Border x:Name="ScanButtonBorder"
                            CornerRadius="10"
                            BorderThickness="0.5"
                            BorderBrush="LightGray"
                            Background="White"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,20">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24"
                                              ShadowDepth="3"
                                              Direction="270"
                                              Opacity="0.35"
                                              Color="#66000000"/>
                        </Border.Effect>
                        <Button Background="Transparent"
                                BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Cursor="Hand"
                                Width="135"
                                Height="35"
                                Command="{Binding ScanDeviceCommand}"
                                PreviewMouseLeftButtonDown="ScanButton_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="ScanButton_PreviewMouseLeftButtonUp"
                                MouseLeave="ScanButton_MouseLeave">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                  RecognizesAccessKey="True"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="扫描设备" FontSize="14" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"  Style="{StaticResource FieldLabelStyle}"/>
                        </Button>
                    </Border>
                </Grid>

            </Grid>

            <Border HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Height="10"
                    CornerRadius="0,0,10,10"
                    Margin="0,0,0,0"
                    Background="Red"></Border>
        </Grid>
    </Grid>
</UserControl>
