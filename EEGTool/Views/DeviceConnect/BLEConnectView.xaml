<UserControl x:Class="EEGTool.Views.DeviceConnect.BLEConnectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EEGTool.Views.DeviceConnect"
             xmlns:vm="clr-namespace:EEGTool.ViewModels.DeviceConnect"
             xmlns:hp="clr-namespace:FrameWork.Helper"
             xmlns:rs="clr-namespace:Resources"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">

    <UserControl.Resources>
        <SolidColorBrush x:Key="MutedBrush" Color="#637487" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:DeviceConnectViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid Width="390" Height="600">

            <Border CornerRadius="10">
                <Border.Background>
                    <LinearGradientBrush
                  StartPoint="1,0"
                  EndPoint="0,1">
                        <GradientStop
                      Color="#FFFFFF"
                      Offset="0" />
                        <GradientStop
                      Color="#D4EAFF"
                      Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>


                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                ShadowDepth="2"
                                Direction="270"
                                Opacity="0.25"
                                Color="#000000"/>
                </Border.Effect>
            </Border>


            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="39"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>

                    <TextBlock Text="蓝牙连接" 
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
                    <Grid Background="LightGray" Height="0.5"
                    HorizontalAlignment="Stretch"
                    Margin="15,0"
                    VerticalAlignment="Bottom"></Grid>
                </Grid>
                <Grid Grid.Row="2" HorizontalAlignment="Stretch"
                      Margin="15,0">
                    <Border Background="Transparent" BorderThickness="0.5"
                            BorderBrush="LightGray"
                            CornerRadius="5"></Border>

                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="ADV Address" 
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"

                                   Style="{StaticResource FieldLabelStyle}"/>
                    </Grid>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
