<UserControl x:Class="EEGTool.Views.Collection.FFTMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:EEGTool.Views.Collection"
             xmlns:vm="clr-namespace:EEGTool.ViewModels.Collection"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <vm:FFTMonitorViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="OtherBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2"/>

                            <ContentPresenter Margin="-5,0,0,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding ItemTemplate}"/>

                            <ToggleButton x:Name="PART_DropDownToggle"
                                          Focusable="False"
                                          Cursor="Hand"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Width="{TemplateBinding Width}"
                                          Height="{TemplateBinding Height}"
                                          BorderThickness="0"
                                          Background="Transparent">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="0">
                                            <Path Data="M 0 0 L 8 8 L 16 0 Z"
                                                  Fill="Black"
                                                  Width="10"
                                                  Height="6"
                                                  Margin="0,0,10,0"
                                                  Stretch="Uniform"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Border" Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   VerticalOffset="5"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="LightGray"
                                        CornerRadius="0"
                                        BorderThickness="1"
                                        BorderBrush="LightGray"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border BorderThickness="1" BorderBrush="LightGray"/>
        <Grid Background="White" Margin="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Background="WhiteSmoke">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="FFT"
                               Margin="10,0"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>
                </Border>

                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,15,0">
                    <TextBlock Text="最大频率(Hz)"
                               Margin="10,0,5,0"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="最大电压(uV)"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Log/Lin"
                               Margin="8,0,18,0"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="平滑系数"
                               Margin="10,0"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="0,0,15,0">
                    <ComboBox Width="70"
                              Height="25"
                              HorizontalAlignment="Left"
                              FontSize="11"
                              Margin="5,0,0,0"
                              VerticalAlignment="Top"
                              ItemsSource="{Binding MaxWindowHz}"
                              SelectedItem="{Binding SelectedMaxWindowHz}"
                              Style="{StaticResource OtherBoxStyle}"/>

                    <ComboBox Width="70"
                              Height="25"
                              HorizontalAlignment="Left"
                              FontSize="11"
                              Margin="5,0,0,0"
                              VerticalAlignment="Top"
                              ItemsSource="{Binding MaxWindowUv}"
                              SelectedItem="{Binding SelectedMaxWindowUv}"
                              Style="{StaticResource OtherBoxStyle}"/>

                    <ComboBox Width="70"
                              Height="25"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top"
                              FontSize="11"
                              Margin="5,0,0,0"
                              ItemsSource="{Binding YAxesType}"
                              SelectedItem="{Binding SelectedYAxesType}"
                              Style="{StaticResource OtherBoxStyle}"/>

                    <ComboBox Width="70"
                              Height="25"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top"
                              Margin="5,0,-3,0"
                              FontSize="11"
                              ItemsSource="{Binding SmoothingFactor}"
                              SelectedItem="{Binding SelectedSmoothingFactor}"
                              Style="{StaticResource OtherBoxStyle}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <ContentControl Margin="12,0,12,12"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Content="{Binding FftPlot, Mode=OneTime}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
