<UserControl x:Class="EEGTool.Views.Collection.EEGMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EEGTool.Views.Collection"
             xmlns:nu="clr-namespace:FrameWork.UserControls.NumericUpDown"
             xmlns:rs="clr-namespace:Resources"
             xmlns:cv="clr-namespace:FrameWork.Converts"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">
    <UserControl.Resources>
        <cv:BoolToBrushConverter
            x:Key="IsEnableBrush"
            TrueBrush="LightGray"
            FalseBrush="#0D0D0D"></cv:BoolToBrushConverter>
        <cv:InverseBoolConverter
            x:Key="InverseBool" />
        <cv:BoolToImageConverter
            x:Key="EegAutoImage"
            TrueImageSource="{x:Static rs:ResourcesImagePath.EEG_AUTO_ON}"
            FalseImageSource="{x:Static rs:ResourcesImagePath.EEG_AUTO_OFF}" />
        <Style
            x:Key="ComboBoxStyle"
            TargetType="ComboBox">
            <Setter
                Property="Foreground"
                Value="Black" />
            <Setter
                Property="Background"
                Value="White" />
            <Setter
                Property="Padding"
                Value="0" />
            <Setter
                Property="Template">
                <Setter.Value>
                    <ControlTemplate
                        TargetType="ComboBox">
                        <Grid>
                            <!-- 边框 -->
                            <Border
                                x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5" />

                            <!-- 显示选中项 -->
                            <ContentPresenter
                                Margin="3,0,0,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding ItemTemplate}" />


                            <ToggleButton
                                x:Name="PART_DropDownToggle"
                                Focusable="False"
                                Cursor="Hand"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                BorderThickness="0"
                                Background="Transparent">
                                <ToggleButton.Template>
                                    <ControlTemplate
                                        TargetType="ToggleButton">
                                        <Border
                                            x:Name="Border"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0">
                                            <Path
                                                Data="M 0 0 L 8 8 L 16 0 Z"
                                                Fill="Black"
                                                Width="10"
                                                Height="6"
                                                Margin="0,0,10,0"
                                                Stretch="Uniform"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger
                                                Property="IsMouseOver"
                                                Value="True">
                                                <Setter
                                                    TargetName="Border"
                                                    Property="Background"
                                                    Value="Transparent" />
                                            </Trigger>
                                            <Trigger
                                                Property="IsPressed"
                                                Value="True">
                                                <Setter
                                                    TargetName="Border"
                                                    Property="Background"
                                                    Value="Transparent" />
                                            </Trigger>
                                            <Trigger
                                                Property="IsEnabled"
                                                Value="False">
                                                <Setter
                                                    TargetName="Border"
                                                    Property="Opacity"
                                                    Value="0.5" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>


                            <!-- 下拉列表 -->
                            <Popup
                                x:Name="PART_Popup"
                                VerticalOffset="5"
                                Placement="Bottom"
                                AllowsTransparency="True"
                                Focusable="False"
                                PopupAnimation="Slide"
                                IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border
                                    Background="LightGray"
                                    CornerRadius="0"
                                    BorderThickness="1"
                                    BorderBrush="LightGray"
                                    MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <StackPanel
                                            IsItemsHost="True" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>

                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Border
            BorderThickness="0.5"
            BorderBrush="LightGray" />
        <Grid
            Background="White"
            Margin="1">
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="86" />
                <RowDefinition
                    Height="*" />
            </Grid.RowDefinitions>
            <Grid>
                <Border
                    BorderThickness="0,0,0,0"
                    BorderBrush="LightGray" />
                <ComboBox
                    Width="140"
                    Height="36"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="26,12,0,0"
                    ItemsSource="{Binding ChartItems}"
                    SelectedItem="{Binding SelectedChartItem,Mode=TwoWay}"
                    Style="{StaticResource ComboBoxStyle}">
                    <!-- 下拉列表样式 -->
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel
                                Orientation="Horizontal"
                                Margin="3,0,0,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left">
                                <Image
                                    Width="42"
                                    Height="30"
                                    Source="{Binding ImgSource}" />
                                <TextBlock
                                    Text="{Binding Text}"
                                    Margin="5,0,0,0"
                                    FontSize="18"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel
                    Visibility="Collapsed"
                    Orientation="Horizontal"
                    Margin="0 0 530 0"
                    HorizontalAlignment="Right">

                    <StackPanel
                        Margin="10 0 ">

                        <TextBox
                            Margin="10 10 20 0"
                            Width="70"
                            Height="40"
                            FontSize="18"
                            FontFamily="Microsoft YaHei"
                            Foreground="#333333"
                            Background="White"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            IsReadOnly="False"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"
                            TextAlignment="Center"
                            MaxLength="10"
                            AcceptsReturn="False" />

                        <Label
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Height="40"
                            FontSize="18"
                            Content="时间常数">
                        </Label>

                    </StackPanel>

                    <StackPanel>
                        <ComboBox
                            Margin="0 10 0 0"
                            Width="135"
                            Height="40"
                            FontSize="18"
                            SelectedIndex="0"
                            SelectedItem="{Binding SelectedUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">


                            <ComboBoxItem
                                Content="不设置" />
                            <ComboBoxItem
                                Content="1uV/mm" />
                            <ComboBoxItem
                                Content="10uV/mm" />
                            <ComboBoxItem
                                Content="50uV/mm" />
                            <ComboBoxItem
                                Content="100uV/mm" />
                            <ComboBoxItem
                                Content="0.01mm/uV" />
                            <ComboBoxItem
                                Content="0.05mm/uV" />
                            <ComboBoxItem
                                Content="0.1mm/uV" />

                        </ComboBox>

                        <Label
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Height="40"
                            FontSize="18"
                            Content="灵敏度（增益）">
                        </Label>

                    </StackPanel>





                </StackPanel>



                <StackPanel
                    Orientation="Vertical"
                    Margin="0,12,235,0"
                    Width="100"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">
                    <Grid
                        Height="36">
                        <nu:BZNumericUpDown
                            Width="100"
                            Height="35"
                            MaxValue="15"
                            MinValue="1"
                            IsDecimal="False"
                            Value="{Binding WindowSec}"
                            Step="1" />
                    </Grid>
                    <TextBlock
                        FontSize="12"
                        Margin="0,5,0,0"
                        HorizontalAlignment="Center"
                        Text="窗口时间(秒)" />
                </StackPanel>

                <StackPanel
                    Orientation="Vertical"
                    Margin="0,12,120,0"
                    Width="100"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">
                    <Grid
                        Height="36">
                        <nu:BZNumericUpDown
                            MaxValue="10000"
                            Width="90"
                            Height="35"
                            MinValue="1"
                            IsEnabled="{Binding IsAuto,Converter={StaticResource InverseBool}}"
                            IsDecimal="False"
                            Foreground="{Binding IsAuto,Converter={StaticResource IsEnableBrush}}"
                            Value="{Binding VertScale}"
                            Step="10" />
                    </Grid>
                    <TextBlock
                        FontSize="12"
                        Margin="0,5,0,0"
                        HorizontalAlignment="Center"
                        Text="垂直刻度uV/div"
                        Foreground="{Binding IsAuto,Converter={StaticResource IsEnableBrush}}" />
                </StackPanel>

                <Button
                    Width="100"
                    Height="69"
                    Margin="0,5,10,0"
                    HorizontalAlignment="Right"
                    BorderThickness="0"
                    Padding="0"
                    Background="Transparent"
                    VerticalAlignment="Top"
                    Command="{Binding EegAutoClickCommand}">
                    <Grid>
                        <Image
                            Width="80"
                            Height="59"
                            Source="{Binding IsAuto,Converter={StaticResource EegAutoImage}}" />
                        <TextBlock
                            Text="波形自适应"
                            Foreground="Black"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,5"
                            FontSize="12" />
                    </Grid>
                </Button>
            </Grid>
            <Grid
                Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="1303*" />
                    <ColumnDefinition
                        Width="616*" />
                </Grid.ColumnDefinitions>

                <ContentControl
                    Margin="108,0,20,20"
                    Content="{Binding EegPlot, Mode=OneTime}"
                    Grid.ColumnSpan="2" />
                <Grid
                    Width="126"
                    HorizontalAlignment="Left"
                    Panel.ZIndex="100">
                    <ListBox
                        ItemsSource="{Binding ChannelHeaders}"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        Margin="0,0,0,67"
                        BorderThickness="0"
                        VerticalAlignment="Stretch"
                        Focusable="False"
                        HorizontalAlignment="Stretch"
                        Background="Transparent">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <!-- ⚠️ 不要绑 Rows，自动计算行数即可 -->
                                <UniformGrid
                                    Columns="1" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemContainerStyle>
                            <Style
                                TargetType="ListBoxItem">
                                <Setter
                                    Property="Background"
                                    Value="Transparent" />
                                <Setter
                                    Property="BorderThickness"
                                    Value="0" />
                                <Setter
                                    Property="Focusable"
                                    Value="False" />
                                <Setter
                                    Property="HorizontalContentAlignment"
                                    Value="Stretch" />
                                <Setter
                                    Property="VerticalContentAlignment"
                                    Value="Stretch" />
                                <Setter
                                    Property="Padding"
                                    Value="0" />
                                <Setter
                                    Property="Margin"
                                    Value="0" />
                                <Setter
                                    Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate
                                            TargetType="ListBoxItem">
                                            <Border
                                                Background="Transparent"
                                                BorderThickness="0">
                                                <ContentPresenter
                                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid
                                    Opacity="{Binding OpacityValue}">
                                    <Rectangle
                                        Height="1"
                                        Stroke="#858585"
                                        StrokeThickness="1"
                                        StrokeDashArray="5,6"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Top"
                                        Margin="0,-1.2,0,0"
                                        SnapsToDevicePixels="True" />
                                    <Button
                                        Width="116"
                                        Height="25"
                                        Padding="0"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Focusable="False"
                                        CommandParameter="{Binding}"
                                        Command="{Binding DataContext.ClickChannelHeaderCommand,RelativeSource={RelativeSource AncestorType=UserControl}}">
                                        <Button.Template>
                                            <ControlTemplate
                                                TargetType="Button">
                                                <Border
                                                    Background="{TemplateBinding Background}">
                                                    <ContentPresenter
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>

                                        <StackPanel
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                            <Grid
                                                Width="42"
                                                Height="23">
                                                <Border
                                                    CornerRadius="3"
                                                    Background="{Binding ImpedanceColor}" />
                                                <TextBlock
                                                    Text="{Binding ImpedanceValue}"
                                                    Foreground="White"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                            </Grid>

                                            <Grid
                                                Width="72"
                                                Height="23"
                                                Margin="1,0,0,0">
                                                <Border
                                                    BorderThickness="1"
                                                    BorderBrush="#8DBEFF"
                                                    CornerRadius="3"
                                                    Background="#F9FCFF" />
                                                <TextBlock
                                                    Text="{Binding ChannelId}"
                                                    Margin="3,0,0,0"
                                                    Foreground="#3A4B63"
                                                    FontSize="11"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center" />
                                                <TextBlock
                                                    Text="{Binding EleTag}"
                                                    Margin="0,0,3,0"
                                                    Foreground="#5E6A7A"
                                                    FontSize="11"
                                                    TextTrimming="CharacterEllipsis"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center" />
                                            </Grid>
                                        </StackPanel>
                                    </Button>

                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Rectangle
                        Height="1"
                        Width="126"
                        Margin="0,0,0,66.5"
                        Stroke="#858585"
                        StrokeThickness="1"
                        StrokeDashArray="5,6"
                        SnapsToDevicePixels="True"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom" />
                </Grid>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
