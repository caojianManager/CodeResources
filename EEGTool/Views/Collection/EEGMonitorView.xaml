<UserControl x:Class="EEGTool.Views.Collection.EEGMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EEGTool.Views.Collection"
             xmlns:nu="clr-namespace:FrameWork.UserControls.NumericUpDown"
             xmlns:vm="clr-namespace:EEGTool.ViewModels.Collection"
             xmlns:cv="clr-namespace:FrameWork.Converts"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">

    <UserControl.DataContext>
        <vm:EEGMonitorViewModel/>
    </UserControl.DataContext>


    <UserControl.Resources>
        <cv:BoolToBrushConverter
            x:Key="IsEnableBrush"
            TrueBrush="LightGray"
            FalseBrush="#334155"></cv:BoolToBrushConverter>
        <cv:InverseBoolConverter
            x:Key="InverseBool" />
        <Style
            x:Key="ComboBoxStyle"
            TargetType="ComboBox">
            <Setter
                Property="Foreground"
                Value="Black" />
            <Setter
                Property="Background"
                Value="White" />
            <Setter
                Property="Padding"
                Value="0" />
            <Setter
                Property="Template">
                <Setter.Value>
                    <ControlTemplate
                        TargetType="ComboBox">
                        <Grid>
                            <!-- 边框 -->
                            <Border
                                x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2" />

                            <!-- 显示选中项 -->
                            <ContentPresenter
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding ItemTemplate}" />


                            <ToggleButton
                                x:Name="PART_DropDownToggle"
                                Focusable="False"
                                Cursor="Hand"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                BorderThickness="0"
                                Background="Transparent">
                                <ToggleButton.Template>
                                    <ControlTemplate
                                        TargetType="ToggleButton">
                                        <Border
                                            x:Name="Border"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0">
                                            <Path
                                                Data="M 0 0 L 8 8 L 16 0 Z"
                                                Fill="Black"
                                                Width="10"
                                                Height="6"
                                                Margin="0,0,10,0"
                                                Stretch="Uniform"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger
                                                Property="IsMouseOver"
                                                Value="True">
                                                <Setter
                                                    TargetName="Border"
                                                    Property="Background"
                                                    Value="Transparent" />
                                            </Trigger>
                                            <Trigger
                                                Property="IsPressed"
                                                Value="True">
                                                <Setter
                                                    TargetName="Border"
                                                    Property="Background"
                                                    Value="Transparent" />
                                            </Trigger>
                                            <Trigger
                                                Property="IsEnabled"
                                                Value="False">
                                                <Setter
                                                    TargetName="Border"
                                                    Property="Opacity"
                                                    Value="0.5" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>


                            <!-- 下拉列表 -->
                            <Popup
                                x:Name="PART_Popup"
                                VerticalOffset="5"
                                Placement="Bottom"
                                AllowsTransparency="True"
                                Focusable="False"
                                PopupAnimation="Slide"
                                IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border
                                    Background="LightGray"
                                    CornerRadius="0"
                                    BorderThickness="1"
                                    BorderBrush="LightGray"
                                    MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <StackPanel
                                            IsItemsHost="True" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>

                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MonitorOptionButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="54"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#EAF4FF"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#5DA9E9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="#D7ECFF"/>
                    <Setter Property="BorderBrush" Value="#378CF3"/>
                    <Setter Property="Foreground" Value="#0F4C81"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Border
            BorderThickness="0.5"
            BorderBrush="LightGray" />
        <Grid
            Background="White"
            Margin="1">
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="60" />
                <RowDefinition
                    Height="*" />
            </Grid.RowDefinitions>
            <Grid Background="WhiteSmoke">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="EEG"
                               Margin="10,0"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>
                </Border>

                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,15,0">
                    <TextBlock Text="窗口时间(s)"
                               Margin="10,0"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="垂直刻度(uV)"
                               Margin="8,0,10,0"
                               VerticalAlignment="Center"
                               Foreground="{Binding IsAuto,Converter={StaticResource IsEnableBrush}}" 
                               FontWeight="SemiBold"/>
                    <TextBlock Text="自动"
                               Margin="20,0,26,0"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="模式切换"
                               Margin="10,0"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="0,0,15,0">
                        <nu:BZNumericUpDown
                            Width="80"
                            Height="25"
                            MaxValue="15"
                            MinValue="1"
                            IsDecimal="False"
                            Value="{Binding WindowSec}"
                            Step="1" />
                        <nu:BZNumericUpDown
                            Margin="5,0,0,0"
                            MaxValue="10000"
                            Width="80"
                            Height="25"
                            MinValue="1"
                            IsEnabled="{Binding IsAuto,Converter={StaticResource InverseBool}}"
                            IsDecimal="False"
                            Foreground="{Binding IsAuto,Converter={StaticResource IsEnableBrush}}"
                            Value="{Binding VertScale}"
                            Step="10" />

                        <ComboBox Width="65"
                                  Height="25"
                                  FontSize="11"
                                  Margin="5,0,0,0"
                                  SelectedIndex="{Binding AutoModeSelectedIndex, Mode=TwoWay}"
                                  Style="{StaticResource ComboBoxStyle}">
                            <ComboBoxItem Content="否"/>
                            <ComboBoxItem Content="是"/>
                        </ComboBox>
                        <ComboBox Width="65"
                                  Height="25"
                                  Margin="5,0,1,0"
                                  FontSize="11"
                                  SelectedIndex="{Binding ScrollModeSelectedIndex, Mode=TwoWay}"
                                  Style="{StaticResource ComboBoxStyle}">
                            <ComboBoxItem Content="Wipe"/>
                            <ComboBoxItem Content="Scroll"/>
                        </ComboBox>
                    </StackPanel>

    


            </Grid>
            <Grid
                Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="60" />
                    <ColumnDefinition
                        Width="*" />
                </Grid.ColumnDefinitions>

                <Grid>
                    <Canvas Width="60" ClipToBounds="True" Margin="15,0,0,0">
                        <ItemsControl ItemsSource="{Binding WaveHeaderItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style>
                                    <Setter Property="Canvas.Top" Value="{Binding ItemOffsetY}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="50" Width="50" Opacity="{Binding OpacityValue}">
                                        <Grid Height="39"
                                              Width="39"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center">
                                            <Button Margin="0"
                                             Width="38"
                                             Height="38"
                                             Padding="0"
                                             Background="Transparent"
                                             BorderBrush="Transparent"
                                             CommandParameter="{Binding}"
                                             Command="{Binding DataContext.ClickWaveHeaderCommand,RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                <Grid Width="36" Height="36"
                                                      Margin="0,0,0,0">
                                                    <Border BorderThickness="1" BorderBrush="#108EFF" CornerRadius="25"/>
                                                 
                                                    <StackPanel Orientation="Vertical"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                        <TextBlock
                                                            FontSize="8"
                                                            HorizontalAlignment="Center"
                                                            Text="{Binding ElectrodeName}" Foreground="Black"/>
                                                        <Grid Background="Gray" Height="1"
                                                              Margin="0,0"></Grid>
                                                        <TextBlock
                                                            FontSize="8"
                                                            Text="{Binding Channel}" Foreground="Black"/>
                                                    </StackPanel>
                                                    
                                                </Grid>
                                            </Button>

                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </Canvas>
                </Grid>

                <ContentControl Grid.Column="1"
           Margin="0"
           HorizontalAlignment="Stretch"
           VerticalAlignment="Stretch"
           PreviewMouseWheel="EegPlot_PreviewMouseWheel"
           PreviewMouseLeftButtonDown="EegPlot_PreviewMouseLeftButtonDown"
           PreviewMouseLeftButtonUp="EegPlot_PreviewMouseLeftButtonUp"
           PreviewMouseMove="EegPlot_PreviewMouseMove"
           LostMouseCapture="EegPlot_LostMouseCapture"
           SizeChanged="EegPlot_SizeChanged"
           Content="{Binding EegPlot, Mode=OneTime}" />
            </Grid>

        </Grid>
    </Grid>
</UserControl>
