<UserControl x:Class="EEGTool.Views.Collection.BandPowerMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:EEGTool.ViewModels.Collection"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.DataContext>
        <vm:BandPowerMonitorViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="BandComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="#9CA3AF"
                                    BorderThickness="1"/>
                            <ContentPresenter Margin="5,0,18,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding ItemTemplate}"/>
                            <ToggleButton Focusable="False"
                                          Cursor="Hand"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Width="{TemplateBinding Width}"
                                          Height="{TemplateBinding Height}"
                                          BorderThickness="0"
                                          Background="Transparent">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Path Data="M 0 0 L 7 7 L 14 0 Z"
                                              Fill="#111827"
                                              Width="8"
                                              Height="5"
                                              Margin="0,0,6,0"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="White"
                                        BorderThickness="1"
                                        BorderBrush="#9CA3AF"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Border BorderThickness="1"
                BorderBrush="#72767A"/>

        <Grid Margin="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition Height="22"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Background="#9B9B9B">
                <ComboBox Width="160"
                          Height="20"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          ItemsSource="{Binding ChannelItems}"
                          SelectedItem="{Binding SelectedChannel}"
                          Style="{StaticResource BandComboBoxStyle}"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="Smooth"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="#0F172A"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Filters?"
                               Margin="16,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="#0F172A"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1"
                  Background="#E5E7EB">
                <TextBlock Text="Channels"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Foreground="#0F172A"/>

                <Path Data="M 0 7 L 6 0 L 12 7 Z"
                      Fill="#0F172A"
                      Width="10"
                      Height="6"
                      Stretch="Uniform"
                      Margin="64,0,0,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <ComboBox Width="66"
                              Height="20"
                              ItemsSource="{Binding SmoothItems}"
                              SelectedItem="{Binding SelectedSmooth}"
                              Style="{StaticResource BandComboBoxStyle}"/>
                    <ComboBox Width="62"
                              Height="20"
                              Margin="2,0,0,0"
                              ItemsSource="{Binding FilterItems}"
                              SelectedItem="{Binding SelectedFilter}"
                              Style="{StaticResource BandComboBoxStyle}"/>
                </StackPanel>
            </Grid>

            <ContentControl Grid.Row="2"
                            Margin="8,8,8,10"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Content="{Binding BandPowerPlot, Mode=OneTime}"/>
        </Grid>
    </Grid>
</UserControl>
