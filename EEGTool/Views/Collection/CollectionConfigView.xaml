<UserControl x:Class="EEGTool.Views.Collection.CollectionConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EEGTool.Views.Collection"
             xmlns:vm="clr-namespace:EEGTool.ViewModels.Collection"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">

    <UserControl.DataContext>
        <vm:CollectionConfigViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <SolidColorBrush x:Key="MutedBrush" Color="#637487" />
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style x:Key="SureActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0071BC" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#0071BC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Content" Value="连  接" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                         Background="{TemplateBinding Background}"
                         BorderBrush="{TemplateBinding BorderBrush}"
                         BorderThickness="{TemplateBinding BorderThickness}"
                         CornerRadius="5"
                         RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.90" ScaleY="0.90" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                    <Setter Property="Background" Value="#D83A3A" />
                    <Setter Property="BorderBrush" Value="#D83A3A" />
                    <Setter Property="Content" Value="断开连接" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DataContext.IsConnecting, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                    <Setter Property="Content" Value="连接中..." />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style
     x:Key="RoundCornerComboBoxStyle"
     TargetType="{x:Type ComboBox}">
            <!-- 设置默认尺寸（可根据需要调整，或在使用时覆盖） -->
            <Setter
         Property="Width"
         Value="279" />
            <Setter
         Property="Height"
         Value="30" />
            <Setter
         Property="FontSize"
         Value="12" />

            <!-- 渐变背景（核心：可在使用时通过Background属性覆盖） -->
            <Setter
         Property="Background">
                <Setter.Value>
                    <LinearGradientBrush
                 EndPoint="0.5,1"
                 StartPoint="0.5,0">
                        <GradientStop
                     Color="#FFFCFCFC" />
                        <GradientStop
                     Color="#FFE6E6E6"
                     Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>

            <!-- 核心：圆角ControlTemplate 修复点击区域 -->
            <Setter
         Property="Template">
                <Setter.Value>
                    <ControlTemplate
                 TargetType="{x:Type ComboBox}">
                        <Grid>
                            <!-- 1. 新增列定义：左侧内容区 + 右侧箭头区 -->
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition
                             Width="*" />
                                <ColumnDefinition
                             Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- ComboBox主体圆角容器 -->
                            <Border
                         x:Name="border"
                         Grid.ColumnSpan="2"
                         CornerRadius="5"
                         Background="{TemplateBinding Background}"
                         BorderThickness="0" />

                            <!-- 2. 关键修复：ToggleButton铺满整个ComboBox，接收所有点击 -->
                            <ToggleButton
                         x:Name="toggleButton"
                         Grid.ColumnSpan="2"
                         Focusable="False"
                         IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                         ClickMode="Press"
                         Background="Transparent"
                         BorderThickness="0" />

                            <!-- 3. 选中内容显示区域（左侧） -->
                            <ContentPresenter
                         x:Name="contentPresenter"
                         Margin="10,0,0,0"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         Content="{TemplateBinding SelectionBoxItem}"
                         ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />

                            <!-- 4. 固定箭头图标（右侧） -->
                            <Path
                         Grid.Column="1"
                         x:Name="Arrow"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         Margin="0 0 10 0"
                         Data="M0,0 L0,2 L4,6 L8,2 L8,0 L4,4 z"
                         Fill="#666666" />

                            <!-- 下拉列表：保持原有样式 -->
                            <Popup
                         x:Name="Popup"
                         Grid.ColumnSpan="2"
                         Placement="Bottom"
                         IsOpen="{TemplateBinding IsDropDownOpen}"
                         AllowsTransparency="True"
                         Focusable="False"
                         PopupAnimation="Slide">
                                <Grid
                             x:Name="DropDown"
                             MinWidth="{TemplateBinding ActualWidth}"
                             MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border
                                 x:Name="DropDownBorder"
                                 BorderThickness="1"
                                 BorderBrush="#CCCCCC"
                                 Background="White"
                                 CornerRadius="8" />
                                    <ScrollViewer
                                 Margin="4,6,4,6">
                                        <ItemsPresenter
                                     KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>


    <Grid>
        <Grid Width="390" Height="600">

            <Border CornerRadius="10">
                <Border.Background>
                    <LinearGradientBrush
                           StartPoint="1,0"
                           EndPoint="0,1">
                        <GradientStop
                               Color="#FFFFFF"
                               Offset="0" />
                        <GradientStop
                               Color="#D4EAFF"
                               Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>


                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                         ShadowDepth="2"
                         Direction="270"
                         Opacity="0.25"
                         Color="#000000"/>
                </Border.Effect>
            </Border>


            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="39"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="50"/>

                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>

                    <TextBlock Text="采集配置" 
                              HorizontalAlignment="Center"
                              FontSize="14"
                              VerticalAlignment="Center"/>
                    <Grid Background="LightGray" Height="0.5"
                         HorizontalAlignment="Stretch"
                         Margin="15,0"
                         VerticalAlignment="Bottom"></Grid>
               
                </Grid>
                <Grid Grid.Row="2" HorizontalAlignment="Stretch"
                    Margin="15,0">
                    <Border Background="Transparent" BorderThickness="0.5"
                     BorderBrush="LightGray"
                     CornerRadius="5"></Border>

                    <Grid Margin="15,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="1*"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>



                        <TextBlock Grid.Row="0" Grid.Column="0" Text="设备名称:" 
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentDeviceName}" 
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelStyle}"/>


                        <TextBlock Grid.Row="0" Grid.Column="2" Text="连接状态:" 
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding CurrentConnectionStatus}" 
                            Foreground="{Binding CurrentConnectionStatusBrush}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource FieldLabelStyle}"/>


                        <TextBlock Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="4"
                            Text="提示：前先完成好设备的连接，再进行采集配置"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Foreground="#ec3b09"
                            Style="{StaticResource FieldLabelStyle}"></TextBlock>
                    </Grid>
                </Grid>

                <Grid Grid.Row="3"
                      Margin="15,15,15,100">
                    <Border HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            BorderThickness="0.5"
                            CornerRadius="5"
                            BorderBrush="LightGray"></Border>


                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="采样率:" VerticalAlignment="Center" HorizontalAlignment="Right"></TextBlock>

                        <ComboBox Grid.Row="0" Grid.Column="1" Width="150" Height="25"
                                  FontSize="14"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Margin="20,0,0,0"
                                  ItemsSource="{Binding SampleRateItems}"
                                  SelectedItem="{Binding SelectedSampleRate}"
                                  Style="{StaticResource RoundCornerComboBoxStyle}" Cursor=""/>


                        <TextBlock Grid.Row="1" Grid.Column="0" Text="采样模板:" VerticalAlignment="Center" HorizontalAlignment="Right"></TextBlock>

                        <ComboBox Grid.Row="1" Grid.Column="1" Width="150" Height="25"
                                  FontSize="14"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Margin="20,0,0,0"
                                  ItemsSource="{Binding TemplateItems}"
                                  SelectedItem="{Binding SelectedTemplate}"
                                  Style="{StaticResource RoundCornerComboBoxStyle}" Cursor=""/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="视频录制:" VerticalAlignment="Center" HorizontalAlignment="Right"></TextBlock>

                        <StackPanel Grid.Row="2" Grid.Column="1"
                                    Orientation="Horizontal"
                                    Margin="20,0,0,0"
                                    VerticalAlignment="Center">
                            <RadioButton Content="是"
                                         Background="Transparent"
                                         GroupName="VideoRecordGroup"
                                         IsChecked="{Binding IsVideoRecordYes, Mode=TwoWay}"
                                         Margin="0,0,20,0"
                                         VerticalAlignment="Center"/>
                            <RadioButton Content="否"
                                         GroupName="VideoRecordGroup"
                                         Background="Transparent"
                                         IsChecked="{Binding IsVideoRecordNo, Mode=TwoWay}"
                                         VerticalAlignment="Center"/>
                        </StackPanel>
                        
                    </Grid>
       
                </Grid>

                <Grid Grid.Row="3" ClipToBounds="False">
                    <Border x:Name="ScanButtonBorder"
                     CornerRadius="10"
                     BorderThickness="0.5"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Bottom"
                     Margin="0,0,0,20">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="BorderBrush" Value="LightGray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanCollection}" Value="False">
                                        <Setter Property="Background" Value="#D9D9D9"/>
                                        <Setter Property="BorderBrush" Value="#BFBFBF"/>
                                        <Setter Property="Effect" Value="{x:Null}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24"
                                       ShadowDepth="3"
                                       Direction="270"
                                       Opacity="0.35"
                                       Color="#66000000"/>
                        </Border.Effect>
                        <Button Background="Transparent"
                         BorderThickness="0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         Cursor="Hand"
                         Width="135"
                         Height="35"
                         IsEnabled="{Binding CanCollection}"
                         Command="{Binding CollectionCommand}"
                         PreviewMouseLeftButtonDown="ScanButton_PreviewMouseLeftButtonDown"
                         PreviewMouseLeftButtonUp="ScanButton_PreviewMouseLeftButtonUp"
                         MouseLeave="ScanButton_MouseLeave">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FFFFFF"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="#637487"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                               VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                               RecognizesAccessKey="True"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Background" Value="#D9D9D9"/>
                                            <Setter Property="Foreground" Value="#8F8F8F"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="开始采集" FontSize="14" HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanCollection}" Value="False">
                                                <Setter Property="Foreground" Value="#8F8F8F"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </Border>
                </Grid>

            </Grid>


        </Grid>
    </Grid>
</UserControl>
