<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:presentationOptions="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:crk="clr-namespace:FrameWork.Themes.ComponentResourceKeys">

    <!--Color-->
    <Color x:Key="{x:Static crk:Colors.RedColor}">#EA2D2D</Color>
    <Color x:Key="{x:Static crk:Colors.YellowColor}">#EFEF30</Color>
    <Color x:Key="{x:Static crk:Colors.GreenColor}">#19D119</Color>
    <Color x:Key="{x:Static crk:Colors.BrownColor}">#8C2222</Color>
    <Color x:Key="{x:Static crk:Colors.BlueColor}">#1871D3</Color>
    <Color x:Key="{x:Static crk:Colors.DarkBlueColor}">#124E84</Color>
    <Color x:Key="{x:Static crk:Colors.BlueGrayColor}">#4D7489</Color>
    <Color x:Key="{x:Static crk:Colors.OrangeColor}">#FAAD14</Color>
    
    <!--Brush-->
    <ImageBrush x:Key="{x:Static crk:Brushes.WindowBackgroundImage}" ImageSource="pack://application:,,,/DrugControlApp;component/Resource/images/heads/bg3.png"/>

    <SolidColorBrush x:Key="{x:Static crk:Brushes.BrushesBlue}" Color="{DynamicResource {x:Static crk:Colors.BlueColor}}" presentationOptions:Freeze="True"/>
</ResourceDictionary>