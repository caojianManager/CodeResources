<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Alibaba PuHuiTi 3.0 55 Regular"/>
    </Style>

    <Style x:Key="AliPhBold" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Alibaba PuHuiTi 3.0 85 Bold"></Setter>
    </Style>

    <Style x:Key="AliPhMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Alibaba PuHuiTi 3.0 65 Medium"></Setter>
    </Style>

</ResourceDictionary>