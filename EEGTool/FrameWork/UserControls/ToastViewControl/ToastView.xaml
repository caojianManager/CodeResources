<UserControl x:Class="FrameWork.UserControls.ToastViewControl.ToastView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:rs="clr-namespace:Resources"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920"
             Background="Transparent"
             IsHitTestVisible="True"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    <Grid>
        <!-- 透明层，拦截所有点击 -->
        <Rectangle Fill="Black"
                   Opacity="0.2"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"/>

        <!-- 半透明提示框 -->
        <Border Background="White"
                CornerRadius="8"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0"
                Opacity="1"
                IsHitTestVisible="False">
            <Grid>
                <Grid Height="50" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                    <Border Background="#F3F3F3" CornerRadius="8,8,0,0"/>
                    <TextBlock Text="警告弹窗" FontSize="20" 
                               Foreground="#414548"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
                <StackPanel Margin="100,80,100,50" MinHeight="100" MinWidth="300" Orientation="Horizontal">
                    <Image Width="92" Height="78" Source="{x:Static rs:ResourcesImagePath.WARNING_ICON}"/>
                    <TextBlock x:Name="MessageTextBlock"
                               Foreground="#414548"
                               FontSize="26"
                               Text="Toast Message"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="37,0,0,0"
                               TextAlignment="Center"/>

                </StackPanel>
            </Grid>
           
            
        </Border>
    </Grid>
</UserControl>
