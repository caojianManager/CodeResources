<UserControl x:Class="FrameWork.UserControls.NumericUpDown.BZNumericUpDown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             x:Name="root"
             Height="36" Width="120">

    <Grid Background="Transparent">
        <!-- 中间输入框 -->
        <Border 
                Background="White"
                BorderThickness="{Binding InputBorderThickness,ElementName=root}"
                BorderBrush="{Binding InputBorderBrush,ElementName=root}"
                CornerRadius="5">
            <TextBox x:Name="TextBoxValue"
                     Margin="2,0,35,0"
                     FontSize="13"
                     Foreground="{Binding Foreground,ElementName=root}"
                     HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center"
                     BorderThickness="0"
                     PreviewTextInput="TextBox_PreviewTextInput"
                     DataObject.Pasting="TextBox_Pasting"
                     PreviewKeyDown="TextBox_PreviewKeyDown"
                     LostFocus="TextBox_LostFocus"/>
        </Border>

        <Grid Width="1" 
              Background="LightGray"
              HorizontalAlignment="Right"
              VerticalAlignment="Stretch"
              Margin="0,0,35,0"></Grid>

        <!-- 减号按钮 -->
        <Button HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Padding="0"
               BorderThickness="0"
               Background="Transparent"
               Click="Minus_Click">

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Width="35"
                             CornerRadius="0,0,8,0"
                            Height="15"
                            Background="Transparent">
                        <iconPacks:PackIconFontAwesome Kind="AngleDownSolid"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Width="15"
                                               Height="7"
                                               Foreground="#494D50"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd"
                            Property="Background"
                            Value="LightGray"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- 加号按钮 -->
        <Button HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Padding="0"
                BorderThickness="0"
                Background="Transparent"
                Click="Plus_Click">

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Width="35"
                            Height="15"
                            CornerRadius="0,8,0,0"
                            Background="Transparent">
                        <iconPacks:PackIconFontAwesome Kind="AngleUpSolid"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Width="15"
                                               Height="7"
                                               Foreground="#494D50"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd"
                            Property="Background"
                            Value="LightGray"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
