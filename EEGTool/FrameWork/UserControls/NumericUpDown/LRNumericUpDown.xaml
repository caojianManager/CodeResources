<UserControl x:Class="EegAcquisitionSystem.FrameWork.UserControls.NumericUpDown.LRNumericUpDown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EegAcquisitionSystem.FrameWork.UserControls.NumericUpDown"
             x:Name="root"
             Height="36" Width="165">
    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="36"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="75"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="36"/>
        </Grid.ColumnDefinitions>

        <!-- 减号按钮 -->
        <Button Grid.Column="0"
              Padding="0"
              BorderThickness="0"
              Background="Transparent"
              Click="Minus_Click">
            <Border Width="36" Height="36"
                  Background="White"
                  BorderThickness="1"
                  CornerRadius="8"
                  BorderBrush="LightGray">
                <TextBlock Text="−"
                         FontSize="25"
                         Foreground="{Binding Foreground,ElementName=root}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
        </Button>

        <!-- 中间输入框 -->
        <Border Grid.Column="2" 
              Background="White"
              BorderThickness="1"
              BorderBrush="LightGray"
              CornerRadius="8">
            <TextBox x:Name="TextBoxValue"
                   Margin="2"
                   Text="{Binding Value, ElementName=root, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                   FontSize="13"
                   Foreground="{Binding Foreground,ElementName=root}"
                   HorizontalContentAlignment="Center"
                   VerticalContentAlignment="Center"
                   BorderThickness="0"
                   PreviewTextInput="TextBox_PreviewTextInput"
                   DataObject.Pasting="TextBox_Pasting"
                   PreviewKeyDown="TextBox_PreviewKeyDown"
                   LostFocus="TextBox_LostFocus"/>
        </Border>

        <!-- 加号按钮 -->
        <Button Grid.Column="4"
              Padding="0"
              BorderThickness="0"
              Background="Transparent"
              Click="Plus_Click">
            <Border Width="36" Height="36"
                  Background="White"
                  BorderThickness="1"
                  CornerRadius="8"
                  BorderBrush="LightGray">
                <TextBlock Text="+"
                         FontSize="25"
                         Foreground="{Binding Foreground,ElementName=root}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
        </Button>
    </Grid>
</UserControl>
